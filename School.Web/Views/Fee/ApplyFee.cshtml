@{
    ViewData["Title"] = "Apply Fee";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <div id="alertContainer"></div>

    <div class="card" style="border-radius: 16px; border: none; box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
        <div class="card-body p-4">
            <div class="d-flex justify-content-end mb-3">
                <a href="/feeList" class="btn btn-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Back
                </a>
            </div>

            <!-- Top Section -->
            <div class="filter-section" style="background: #f8fafc; border-radius: 12px; padding: 20px; margin-bottom: 20px;">
                <div class="row g-3 align-items-end">
                    <div class="col-lg-3 col-md-4 col-sm-6 col-12">
                        <label for="monthRange" class="form-label">Month Range <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="monthRange" placeholder="Select month range" required readonly style="background: white; cursor: pointer;" />
                    </div>
                    <div class="col-lg-5 col-md-6 col-12">
                        <label class="form-label">Choose</label>
                        <div class="d-flex gap-3 pt-2">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="applyChoice" id="choiceStudent" value="student" checked onchange="toggleChoiceFields()">
                                <label class="form-check-label" for="choiceStudent">Student</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="applyChoice" id="choiceSection" value="section" onchange="toggleChoiceFields()">
                                <label class="form-check-label" for="choiceSection">Section</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="applyChoice" id="choiceClass" value="class" onchange="toggleChoiceFields()">
                                <label class="form-check-label" for="choiceClass">Class</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="applyChoice" id="choiceAll" value="all" onchange="toggleChoiceFields()">
                                <label class="form-check-label" for="choiceAll">All</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Student Selection Section -->
            <div class="filter-section" style="background: #f8fafc; border-radius: 12px; padding: 20px; margin-bottom: 20px;">
                <div class="row g-3 align-items-end">
                    <div class="col-lg-2 col-md-4 col-sm-6 col-12" id="classField">
                        <label for="classId" class="form-label">Class <span class="text-danger">*</span></label>
                        <select class="form-select" id="classId" required onchange="loadSections()">
                            <option value="">-- Select Class --</option>
                        </select>
                    </div>
                    <div class="col-lg-2 col-md-4 col-sm-6 col-12" id="sectionField">
                        <label for="sectionId" class="form-label">Section <span class="text-danger">*</span></label>
                        <select class="form-select" id="sectionId" required disabled onchange="loadStudents()">
                            <option value="">-- Select Section --</option>
                        </select>
                    </div>
                    <div class="col-lg-2 col-md-4 col-sm-6 col-12" id="rollNoField">
                        <label for="rollNo" class="form-label">Roll No</label>
                        <select class="form-select" id="rollNo" onchange="selectStudentByRoll()">
                            <option value="">-- Select Roll --</option>
                        </select>
                    </div>
                    <div class="col-lg-3 col-md-4 col-sm-6 col-12" id="studentField">
                        <label for="studentId" class="form-label">Student</label>
                        <select class="form-select" id="studentId" onchange="selectRollByStudent()">
                            <option value="">-- Select Student --</option>
                        </select>
                    </div>
                    <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                        <label for="filterGrade" class="form-label">Grade</label>
                        <select class="form-select" id="filterGrade">
                            <option value="">-- All Grades --</option>
                        </select>
                    </div>
                    <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                        <label for="filterFeeType" class="form-label">Fee Type <span class="text-danger">*</span></label>
                        <select class="form-select" id="filterFeeType">
                            <option value="">-- All Fee Types --</option>
                        </select>
                    </div>
                    <!-- NEW: Avail Academy Filter -->
                    <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                        <label for="filterAvailAcademy" class="form-label">Avail Academy</label>
                        <select class="form-select" id="filterAvailAcademy">
                            <option value="0">-- All --</option>
                            <option value="1">Yes</option>
                        </select>
                    </div>
                    <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                        <button type="button" class="btn btn-primary w-100" onclick="loadPreview()">
                            <i class="bi bi-search me-1"></i> Preview
                        </button>
                    </div>
                </div>
            </div>

            <!-- Preview Grid -->
            <div class="grid-section">
                <h6 class="mb-3" style="font-weight: 600; color: #475569;">Selected Students Preview</h6>
                <div class="table-responsive">
                    <table class="table table-hover" id="previewTable">
                        <thead>
                            <tr style="background: #f8fafc;">
                                <th style="width: 50px;">Sr#</th>
                                <th>Class</th>
                                <th>Section</th>
                                <th>Roll No</th>
                                <th>Student Name</th>
                                <th>Grade</th>
                                <th>Avail Academy</th>
                                <th style="width: 130px;">Fee</th>
                            </tr>
                        </thead>
                        <tbody id="previewBody">
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">Select options and click Preview to see students</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Description -->
            <div class="mt-4">
                <label for="description" class="form-label">Description</label>
                <input type="text" class="form-control" id="description" placeholder="Optional note or comment" />
            </div>

            <!-- Action Buttons -->
            <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                <a href="/feevoucher" class="btn btn-secondary">
                    <i class="bi bi-x-lg me-1"></i> Close
                </a>
                <button type="button" class="btn btn-primary" id="btnApply" onclick="applyFee()">
                    <i class="bi bi-check-lg me-1"></i> Apply
                </button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/plugins/monthSelect/style.css">
    <style>
        .flatpickr-monthSelect-month.selected,
        .flatpickr-monthSelect-month.startRange,
        .flatpickr-monthSelect-month.endRange {
            background: #008649 !important;
            border-color: #008649 !important;
        }

        .flatpickr-monthSelect-month.inRange {
            background: rgba(0,134,73,0.15) !important;
        }

        .badge-academy-yes {
            background-color: #d1fae5;
            color: #065f46;
            padding: 3px 8px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }

        .badge-academy-no {
            background-color: #f1f5f9;
            color: #64748b;
            padding: 3px 8px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/plugins/monthSelect/index.js"></script>
    <script>
        let previewStudents = [];
        let monthPicker = null;

        $(document).ready(function () {
            monthPicker = flatpickr('#monthRange', {
                plugins: [new monthSelectPlugin({ shorthand: true, dateFormat: 'M Y', altFormat: 'M Y' })],
                mode: 'range',
                dateFormat: 'Y-m',
                altInput: true,
                altFormat: 'M Y',
                defaultDate: [new Date(), new Date()],
                onChange: function (dates, dateStr) { }
            });
            loadDropdowns();
            toggleChoiceFields();
            loadStudents();
        });

        async function loadDropdowns() {
            try {
                const [classes, feeTypes, grades] = await Promise.all([
                    fetch(`${API_BASE}/class`).then(r => r.ok ? r.json() : []),
                    fetch(`${API_BASE}/feetype`).then(r => r.ok ? r.json() : []),
                    fetch(`${API_BASE}/AcademicGrade`).then(r => r.ok ? r.json() : [])
                ]);

                const classSelect = $('#classId');
                classSelect.find('option:not(:first)').remove();
                classes.forEach(c => classSelect.append(`<option value="${c.vid}">${c.vName}</option>`));

                const filterFeeType = $('#filterFeeType');
                filterFeeType.find('option:not(:first)').remove();
                feeTypes.forEach(f => filterFeeType.append(`<option value="${f.vid}">${f.vName}</option>`));

                const gradeSelect = $('#filterGrade');
                gradeSelect.find('option:not(:first)').remove();
                grades.forEach(g => gradeSelect.append(`<option value="${g.vid}">${g.vName}</option>`));

            } catch (error) {
                console.error('Error loading dropdowns:', error);
            }
        }

        function toggleChoiceFields() {
            const choice = $('input[name="applyChoice"]:checked').val();

            $('#classField').toggle(choice !== 'all');
            $('#sectionField').toggle(choice === 'section' || choice === 'student');
            $('#rollNoField').toggle(choice === 'student');
            $('#studentField').toggle(choice === 'student');

            if (choice === 'all') $('#classId').val('');
            if (choice === 'class' || choice === 'all') $('#sectionId').val('').prop('disabled', true);
            if (choice !== 'student') { $('#rollNo').val(''); $('#studentId').val(''); }
        }

                async function loadSections() {
            const classId = $('#classId').val();
            const sectionSelect = $('#sectionId');
            sectionSelect.find('option:not(:first)').remove();
            sectionSelect.prop('disabled', true);

            // Reset section then reload students by class only
            $('#sectionId').val('');
            await loadStudents();  // ← load by class only (sectionId = 0)

            if (!classId) return;

            try {
                const response = await fetch(`${API_BASE}/section/byClass/${classId}`);
                if (response.ok) {
                    const sections = await response.json();
                    sections.forEach(s => sectionSelect.append(`<option value="${s.vid}">${s.vName}</option>`));
                    sectionSelect.prop('disabled', false);
                }
            } catch (error) {
                console.error('Error loading sections:', error);
            }
        }
               async function loadStudents() {
            const classId   = $('#classId').val()   || 0;
            const sectionId = $('#sectionId').val() || 0;

            const rollSelect    = $('#rollNo');
            const studentSelect = $('#studentId');

            rollSelect.find('option:not(:first)').remove();
            studentSelect.find('option:not(:first)').remove();

            try {
                const response = await fetch(`${API_BASE}/Student/students?classId=${classId}&sectionId=${sectionId}`);

                if (response.ok) {
                    const students = await response.json();

                    if (students.length === 0) return;

                    students.forEach(s => {
                        rollSelect.append(
                            `<option value="${s.vid}" data-name="${s.name}">
                                ${s.classRollNo || s.rollNo || '-'}
                            </option>`
                        );
                        studentSelect.append(
                            `<option value="${s.vid}" data-roll="${s.classRollNo || s.rollNo}">
                                ${s.name || '-'}
                            </option>`
                        );
                    });
                }
            } catch (error) {
                console.error('Error loading students:', error);
            }
        }
                let isSyncing = false;

        // ── Sync Roll → Student ───────────────────────────────────────────
        function selectStudentByRoll() {
            if (isSyncing) return;
            isSyncing = true;
            const val = $('#rollNo').val();
            if (val) $('#studentId').val(val).trigger('change');
            isSyncing = false;
        }

        // ── Sync Student → Roll ───────────────────────────────────────────
        function selectRollByStudent() {
            if (isSyncing) return;
            isSyncing = true;
            const val = $('#studentId').val();
            if (val) $('#rollNo').val(val).trigger('change');
            isSyncing = false;
        }
        async function loadPreview() {
            const choice      = $('input[name="applyChoice"]:checked').val();
            const classId     = parseInt($('#classId').val())           || 0;
            const sectionId   = parseInt($('#sectionId').val())         || 0;
            const studentId   = parseInt($('#studentId').val())         || 0;
            const gradeId     = parseInt($('#filterGrade').val())        || 0;
            const feeTypeId   = parseInt($('#filterFeeType').val())      || 0;
            const availAcademy = parseInt($('#filterAvailAcademy').val()) || 0;

            // FeeTypeID is required by the stored procedure
            if (!feeTypeId) {
                toastWarning('Please select a Fee Type');
                return;
            }

            // Validate per choice
            if (choice === 'student' && !studentId) { toastWarning('Please select a Student'); return; }
            if (choice === 'section' && (!classId || !sectionId)) { toastWarning('Please select Class and Section'); return; }
            if (choice === 'class'   && !classId)  { toastWarning('Please select a Class'); return; }

            previewStudents = [];
            $('#previewBody').html('<tr><td colspan="8" class="text-center text-muted py-4"><span class="spinner-border spinner-border-sm me-2"></span>Loading...</td></tr>');

            try {
                const payload = {
                    classID:        choice === 'all' ? 0 : classId,
                    sectionID:      (choice === 'section' || choice === 'student') ? sectionId : 0,
                    studentID:      choice === 'student' ? studentId : 0,
                    gradeID:        gradeId,
                    isAvailAcademy: availAcademy,
                    feeTypeID:      feeTypeId
                };

                const response = await fetch(`${API_BASE}/ApplyFee/preview`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (!response.ok) {
                    toastError('Failed to load preview');
                    renderPreviewGrid();
                    return;
                }

                const students = await response.json();

            previewStudents = students.map(s => ({
            id:             s.studentID,
            className:      s.class       || '-',
            sectionName:    s.section     || '-',
            rollNo:         s.rollNo      || '-',
            studentName:    s.studentName || '-',
            gradeName:      s.grade       || '-',
            isAvailAcademy: s.isAvailAcademy,
            fee:            s.fee         || 0,
            // ── Required for SP ──────────────────
            sectionID:      s.sectionID   || 0,
            gradeID:        s.gradeID     || 0
        }));

                renderPreviewGrid();

                if (previewStudents.length === 0) toastWarning('No students found for selected criteria');

            } catch (error) {
                console.error('Error loading preview:', error);
                toastError('Error loading preview');
                renderPreviewGrid();
            }
        }

        function renderPreviewGrid() {
            const tbody = $('#previewBody');
            tbody.empty();

            if (previewStudents.length === 0) {
                tbody.html('<tr><td colspan="8" class="text-center text-muted py-4">No students found for selected criteria</td></tr>');
                return;
            }

            previewStudents.forEach((student, index) => {
                const academyBadge = student.isAvailAcademy
                    ? `<span class="badge-academy-yes">Yes</span>`
                    : `<span class="badge-academy-no">No</span>`;

                tbody.append(`
                    <tr>
                        <td>${index + 1}</td>
                        <td>${student.className}</td>
                        <td>${student.sectionName}</td>
                        <td><strong>${student.rollNo}</strong></td>
                        <td>${student.studentName}</td>
                        <td>${student.gradeName}</td>
                        <td>${academyBadge}</td>
                        <td>
                            <input type="number"
                                   class="form-control form-control-sm fee-input"
                                   data-index="${index}"
                                   value="${student.fee}"
                                   min="0"
                                   onchange="updateStudentFee(${index}, this.value)" />
                        </td>
                    </tr>
                `);
            });
        }

        function updateStudentFee(index, value) {
            previewStudents[index].fee = parseFloat(value) || 0;
        }

                async function applyFee() {
            const selectedDates = monthPicker.selectedDates;
            const description   = $('#description').val();
            const feeTypeId     = parseInt($('#filterFeeType').val()) || 0;

            if (!selectedDates || selectedDates.length === 0) {
                toastWarning('Please select Month Range'); return;
            }
            if (!feeTypeId) {
                toastWarning('Please select a Fee Type'); return;
            }
            if (previewStudents.length === 0) {
                toastWarning('Please preview students first'); return;
            }

            const monthFrom = selectedDates[0].toISOString().slice(0, 7);
            const monthTo   = selectedDates.length > 1
                                ? selectedDates[1].toISOString().slice(0, 7)
                                : monthFrom;

            const feeData = {
                monthFrom:   monthFrom,
                monthTo:     monthTo,
                description: description,
                feeTypeID:   feeTypeId,
                studentFees: previewStudents.map(s => ({
                    studentId: s.id,
                    sectionID: s.sectionID,    // ← preview se aa raha
                    gradeID:   s.gradeID,      // ← preview se aa raha
                    sessionID: 1,    
                    amount:    s.fee
                }))
            };
            console.log('Fee payload:', JSON.stringify(feeData, null, 2));

            try {
                $('#btnApply').prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span> Applying...');

                const response = await fetch(`${API_BASE}/ApplyFee/apply`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(feeData)
                });

                const result = await response.json();

                if (result.totalSaved > 0) {
                    toastSuccess(`Applied: ${result.totalSaved} | Skipped: ${result.totalSkipped} | Failed: ${result.totalFailed}`);
                    previewStudents = [];
                    renderPreviewGrid();
                } else {
                    toastError(`No fees applied. Skipped: ${result.totalSkipped} | Failed: ${result.totalFailed}`);
                }

            } catch (error) {
                console.error('Error applying fee:', error);
                toastError('Error applying fee');
            } finally {
                $('#btnApply').prop('disabled', false).html('<i class="bi bi-check-lg me-1"></i> Apply');
            }
        }
    </script>
}