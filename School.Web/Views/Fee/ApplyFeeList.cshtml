@{
    ViewData["Title"] = "Apply Fee List";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <div id="alertContainer"></div>

    <div class="card" style="border-radius: 16px; border: none; box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
        <div class="card-body p-4">

            <!-- Header -->
            <div class="d-flex justify-content-end mb-3">
                <a href="/apply-fee" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-1"></i> Apply Fee
                </a>
            </div>

            <!-- Filter Row 1: Month Range + Choose -->
            <div class="filter-section" style="background: #f8fafc; border-radius: 12px; padding: 20px; margin-bottom: 20px;">
                <div class="row g-3 align-items-end">
                    <div class="col-lg-3 col-md-4 col-sm-6 col-12">
                        <label for="monthRange" class="form-label">Month Range</label>
                        <input type="text" class="form-control" id="monthRange"
                               placeholder="Select month range" readonly
                               style="background: white; cursor: pointer;" />
                    </div>
                    <div class="col-lg-6 col-md-6 col-12">
                        <label class="form-label">Choose</label>
                        <div class="d-flex gap-3 pt-1">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="listChoice" id="choiceStudent" value="student" checked onchange="toggleChoiceFields()">
                                <label class="form-check-label" for="choiceStudent">Student</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="listChoice" id="choiceSection" value="section" onchange="toggleChoiceFields()">
                                <label class="form-check-label" for="choiceSection">Section</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="listChoice" id="choiceClass" value="class" onchange="toggleChoiceFields()">
                                <label class="form-check-label" for="choiceClass">Class</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="listChoice" id="choiceAll" value="all" onchange="toggleChoiceFields()">
                                <label class="form-check-label" for="choiceAll">All</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Filter Row 2 -->
            <div class="filter-section" style="background: #f8fafc; border-radius: 12px; padding: 20px; margin-bottom: 20px;">
                <div class="row g-3 align-items-end">
                    <div class="col-lg-2 col-md-4 col-sm-6 col-12" id="classField">
                        <label for="filterClass" class="form-label">Class</label>
                        <select class="form-select" id="filterClass" onchange="loadFilterSections()">
                            <option value="">-- Select Class --</option>
                        </select>
                    </div>
                    <div class="col-lg-2 col-md-4 col-sm-6 col-12" id="sectionField">
                        <label for="filterSection" class="form-label">Section</label>
                        <select class="form-select" id="filterSection" disabled onchange="loadStudents()">
                            <option value="">-- Select Section --</option>
                        </select>
                    </div>
                    <div class="col-lg-2 col-md-4 col-sm-6 col-12" id="rollNoField">
                        <label for="filterRollNo" class="form-label">Roll No</label>
                        <select class="form-select" id="filterRollNo" onchange="selectStudentByRoll()">
                            <option value="">-- Select Roll --</option>
                        </select>
                    </div>
                    <div class="col-lg-2 col-md-4 col-sm-6 col-12" id="studentField">
                        <label for="filterStudent" class="form-label">Student</label>
                        <select class="form-select" id="filterStudent" onchange="selectRollByStudent()">
                            <option value="">-- Select Student --</option>
                        </select>
                    </div>
                    <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                        <label for="filterGrade" class="form-label">Grade</label>
                        <select class="form-select" id="filterGrade">
                            <option value="">-- All Grades --</option>
                        </select>
                    </div>
                    <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                        <label for="filterFeeType" class="form-label">Fee Type</label>
                        <select class="form-select" id="filterFeeType">
                            <option value="">-- All Fee Types --</option>
                        </select>
                    </div>
                    <div class="col-lg-2 col-md-4 col-sm-6 col-12 d-flex gap-2 align-items-end">
                        <button type="button" class="btn btn-primary w-100" onclick="loadList()">
                            <i class="bi bi-search me-1"></i> Preview
                        </button>
                        <button type="button" class="btn btn-outline-secondary" onclick="clearFilters()" title="Clear">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Summary Cards -->
            <div class="row g-3 mb-4" id="summaryCards" style="display:none!important;">
                <div class="col-lg-3 col-md-6 col-12">
                    <div style="background: #f0fdf4; border-radius: 12px; padding: 16px;">
                        <div style="font-size: 12px; color: #16a34a; font-weight: 600;">TOTAL RECORDS</div>
                        <div style="font-size: 24px; font-weight: 700; color: #15803d;" id="totalRecords">0</div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 col-12">
                    <div style="background: #eff6ff; border-radius: 12px; padding: 16px;">
                        <div style="font-size: 12px; color: #2563eb; font-weight: 600;">TOTAL FEE</div>
                        <div style="font-size: 24px; font-weight: 700; color: #1d4ed8;" id="totalFee">0</div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 col-12">
                    <div style="background: #f0fdf4; border-radius: 12px; padding: 16px;">
                        <div style="font-size: 12px; color: #16a34a; font-weight: 600;">CLEARED</div>
                        <div style="font-size: 24px; font-weight: 700; color: #15803d;" id="totalCleared">0</div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 col-12">
                    <div style="background: #fef2f2; border-radius: 12px; padding: 16px;">
                        <div style="font-size: 12px; color: #dc2626; font-weight: 600;">PENDING</div>
                        <div style="font-size: 24px; font-weight: 700; color: #b91c1c;" id="totalPending">0</div>
                    </div>
                </div>
            </div>

            <!-- Client Side Search + Status + Record Count -->
            <div class="d-flex justify-content-between align-items-center mb-3 gap-2 flex-wrap">
                <h6 style="font-weight: 600; color: #475569; margin: 0;">
                    <i class="bi bi-list-ul me-2"></i>PAYMENT RECORDS
                    <span id="recordCount" class="text-muted ms-2" style="font-size: 13px; font-weight: 400;"></span>
                </h6>
                <div class="d-flex gap-2 align-items-center">
                    <select class="form-select form-select-sm" id="clientStatus" style="width: 180px;" onchange="applyClientFilters()">
                        <option value="">-- All Status --</option>
                        <option value="true">Cleared</option>
                        <option value="false">Pending</option>
                    </select>
                    <div class="input-group input-group-sm" style="width: 550px;">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" id="clientSearch"
                               placeholder="Student, Fee Type..."
                               oninput="applyClientFilters()" />
                        @* <button class="btn btn-outline-secondary" type="button" onclick="clearClientSearch()" title="Clear search">
                            <i class="bi bi-x"></i>
                        </button> *@
                    </div>
                </div>
            </div>

            <!-- List -->
            <div class="table-responsive">
                <table class="table table-hover" id="feeListTable">
                    <thead>
                        <tr style="background: #f8fafc;">
                            <th style="width: 50px;">Sr#</th>
                            <th>Date</th>
                            <th>Student</th>
                            <th>Class</th>
                            <th>Section</th>
                            <th>Grade</th>
                            <th>Fee Type</th>
                            <th>Fee Amount</th>
                            <th>Cleared</th>
                            <th>Pending</th>
                            <th>Status</th>
                            <th>Remarks</th>
                            <th style="width: 80px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="feeListBody">
                        <tr>
                            <td colspan="13" class="text-center text-muted py-4">
                                Select filters and click Preview to load records
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 12px; border: none;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title" style="color: #dc2626;">
                    <i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-0">Are you sure you want to delete this fee record?</p>
                <p class="mt-2"><strong id="deleteStudentName"></strong> — <span id="deleteFeeType" class="text-muted"></span></p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="btnConfirmDelete" onclick="confirmDelete()">
                    <i class="bi bi-trash me-1"></i> Delete
                </button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/plugins/monthSelect/style.css">
    <style>
        .flatpickr-monthSelect-month.selected,
        .flatpickr-monthSelect-month.startRange,
        .flatpickr-monthSelect-month.endRange {
            background: #008649 !important;
            border-color: #008649 !important;
        }

        .flatpickr-monthSelect-month.inRange {
            background: rgba(0,134,73,0.15) !important;
        }

        .badge-cleared {
            background-color: #d1fae5;
            color: #065f46;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }

        .badge-pending {
            background-color: #fef2f2;
            color: #b91c1c;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }

        .table th {
            font-size: 13px;
            font-weight: 600;
            color: #475569;
            white-space: nowrap;
        }

        .table td {
            font-size: 13px;
            vertical-align: middle;
        }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/plugins/monthSelect/index.js"></script>
    <script>
        let allData     = [];
        let deleteVID   = null;
        let monthPicker = null;
        let isSyncing   = false;

        $(document).ready(function () {
            const now = new Date();

            monthPicker = flatpickr('#monthRange', {
                plugins: [new monthSelectPlugin({ shorthand: true, dateFormat: 'M Y', altFormat: 'M Y' })],
                mode: 'range',
                dateFormat: 'Y-m',
                altInput: true,
                altFormat: 'M Y'
            });

            // Flatpickr ready hone ke baad default date set karo aur data load karo
            setTimeout(() => {
                monthPicker.setDate([now, now], false);
                loadList();
            }, 50);

            loadDropdowns();
            toggleChoiceFields();
        });

        // ── Toggle Choice Fields ──────────────────────────────────────
        function toggleChoiceFields() {
            const choice = $('input[name="listChoice"]:checked').val();

            $('#classField').toggle(choice !== 'all');
            $('#sectionField').toggle(choice === 'section' || choice === 'student');
            $('#rollNoField').toggle(choice === 'student');
            $('#studentField').toggle(choice === 'student');

            if (choice === 'all') $('#filterClass').val('');
            if (choice === 'class' || choice === 'all') $('#filterSection').val('').prop('disabled', true);
            if (choice !== 'student') { $('#filterRollNo').val(''); $('#filterStudent').val(''); }
        }

        // ── Load Dropdowns ────────────────────────────────────────────
        async function loadDropdowns() {
            try {
                const [classes, feeTypes, grades] = await Promise.all([
                    fetch(`${API_BASE}/class`).then(r => r.ok ? r.json() : []),
                    fetch(`${API_BASE}/feetype`).then(r => r.ok ? r.json() : []),
                    fetch(`${API_BASE}/AcademicGrade`).then(r => r.ok ? r.json() : [])
                ]);

                classes.forEach(c  => $('#filterClass').append(`<option value="${c.vid}">${c.vName}</option>`));
                feeTypes.forEach(f => $('#filterFeeType').append(`<option value="${f.vid}">${f.vName}</option>`));
                grades.forEach(g   => $('#filterGrade').append(`<option value="${g.vid}">${g.vName}</option>`));

            } catch (err) {
                console.error('Error loading dropdowns:', err);
            }
        }

        // ── Load Sections ─────────────────────────────────────────────
        async function loadFilterSections() {
            const classId       = $('#filterClass').val();
            const sectionSelect = $('#filterSection');
            sectionSelect.find('option:not(:first)').remove();
            sectionSelect.prop('disabled', true);
            $('#filterRollNo').find('option:not(:first)').remove();
            $('#filterStudent').find('option:not(:first)').remove();

            if (!classId) return;

            try {
                const response = await fetch(`${API_BASE}/section/byClass/${classId}`);
                if (response.ok) {
                    const sections = await response.json();
                    sections.forEach(s => sectionSelect.append(`<option value="${s.vid}">${s.vName}</option>`));
                    sectionSelect.prop('disabled', false);
                }
            } catch (err) {
                console.error('Error loading sections:', err);
            }

            await loadStudents();
        }

        // ── Load Students ─────────────────────────────────────────────
        async function loadStudents() {
            const classId   = $('#filterClass').val()   || 0;
            const sectionId = $('#filterSection').val() || 0;

            $('#filterRollNo').find('option:not(:first)').remove();
            $('#filterStudent').find('option:not(:first)').remove();

            try {
                const response = await fetch(`${API_BASE}/Student/students?classId=${classId}&sectionId=${sectionId}`);
                if (response.ok) {
                    const students = await response.json();
                    students.forEach(s => {
                        const roll = s.classRollNo || s.rollNo || '-';
                        $('#filterRollNo').append(`<option value="${s.vid}">${roll}</option>`);
                        $('#filterStudent').append(`<option value="${s.vid}">${s.name || '-'}</option>`);
                    });
                }
            } catch (err) {
                console.error('Error loading students:', err);
            }
        }

        // ── Sync Roll ↔ Student ───────────────────────────────────────
        function selectStudentByRoll() {
            if (isSyncing) return;
            isSyncing = true;
            const val = $('#filterRollNo').val();
            if (val) $('#filterStudent').val(val);
            isSyncing = false;
        }

        function selectRollByStudent() {
            if (isSyncing) return;
            isSyncing = true;
            const val = $('#filterStudent').val();
            if (val) $('#filterRollNo').val(val);
            isSyncing = false;
        }

        // ── Server Side Load ──────────────────────────────────────────
        async function loadList() {
            // Dates
            const selectedDates = monthPicker ? monthPicker.selectedDates : [];
            let dateFrom, dateTo;

            if (!selectedDates || selectedDates.length === 0) {
                const now = new Date();
                dateFrom = formatDate(new Date(now.getFullYear(), now.getMonth(), 1));
                dateTo   = formatDate(new Date(now.getFullYear(), now.getMonth() + 1, 0));
            } else {
                const first = selectedDates[0];
                const last  = selectedDates.length > 1 ? selectedDates[selectedDates.length - 1] : selectedDates[0];
                dateFrom = formatDate(new Date(first.getFullYear(), first.getMonth(), 1));
                dateTo   = formatDate(new Date(last.getFullYear(),  last.getMonth() + 1, 0));
            }

            const sectionId = parseInt($('#filterSection').val()) || 0;
            const studentId = parseInt($('#filterStudent').val())  || 0;
            const gradeId   = parseInt($('#filterGrade').val())    || 0;
            const feeTypeId = parseInt($('#filterFeeType').val())  || 0;

            $('#feeListBody').html('<tr><td colspan="13" class="text-center text-muted py-4"><span class="spinner-border spinner-border-sm me-2"></span>Loading...</td></tr>');

            try {
                let url = `${API_BASE}/ApplyFee?dateFrom=${dateFrom}&dateTo=${dateTo}`;
                if (sectionId) url += `&sectionId=${sectionId}`;

                const response = await fetch(url);

                if (!response.ok) {
                    toastError('Failed to load records');
                    $('#feeListBody').html('<tr><td colspan="13" class="text-center text-muted py-4">No records found</td></tr>');
                    return;
                }

                let data = await response.json();

                // Client side filters
                if (studentId) data = data.filter(d => d.studentID === studentId);
                if (gradeId)   data = data.filter(d => d.gradeID   === gradeId);
                if (feeTypeId) data = data.filter(d => d.feeTypeID === feeTypeId);

                allData = data;

                $('#clientSearch').val('');
                $('#clientStatus').val('');

                applyClientFilters();

            } catch (err) {
                console.error('Error loading list:', err);
                toastError('Error loading records');
                $('#feeListBody').html('<tr><td colspan="13" class="text-center text-muted py-4">No records found</td></tr>');
            }
        }

        // ── Client Side Filters ───────────────────────────────────────
        function applyClientFilters() {
            const search = $('#clientSearch').val().toLowerCase().trim();
            const status = $('#clientStatus').val();

            let filtered = [...allData];

            if (search) {
                filtered = filtered.filter(d =>
                    (d.studentName || '').toLowerCase().includes(search) ||
                    (d.feeTypeName || '').toLowerCase().includes(search) ||
                    (d.className   || '').toLowerCase().includes(search) ||
                    (d.sectionName || '').toLowerCase().includes(search)
                );
            }

            if (status !== '') {
                filtered = filtered.filter(d => String(d.isClear) === status);
            }

            renderList(filtered);
        }

        function clearClientSearch() {
            $('#clientSearch').val('');
            $('#clientStatus').val('');
            applyClientFilters();
        }

        // ── Render List ───────────────────────────────────────────────
                function renderList(data) {
            const tbody = $('#feeListBody');

            if (data.length === 0) {
                tbody.html('<tr><td colspan="13" class="text-center text-muted py-4">No records found</td></tr>');
                updateSummary([]);
                return;
            }

            // Saari rows ek string mein banao — ek baar DOM update
            let rows = '';
            data.forEach((row, index) => {
                const statusBadge = row.isClear
                    ? `<span class="badge-cleared">Cleared</span>`
                    : `<span class="badge-pending">Pending</span>`;

                const vDate = new Date(row.vDate).toLocaleDateString('en-GB', {
                    day: '2-digit', month: 'short', year: 'numeric'
                });

                const canDelete = row.clearedAmount === 0 && row.isClear === false;
                const deleteBtn = canDelete
                    ? `<button class="btn btn-danger btn-sm"
                            onclick="openDeleteModal(${row.vid}, '${(row.studentName || '').replace(/'/g, "\\'")}', '${(row.feeTypeName || '').replace(/'/g, "\\'")}')">
                            <i class="bi bi-trash"></i>
                       </button>`
                    : `<span class="text-muted">—</span>`;

                rows += `
                    <tr>
                        <td>${index + 1}</td>
                        <td>${vDate}</td>
                        <td><strong>${row.studentName || '-'}</strong></td>
                        <td>${row.className    || '-'}</td>
                        <td>${row.sectionName  || '-'}</td>
                        <td>${row.gradeName    || '-'}</td>
                        <td>${row.feeTypeName  || '-'}</td>
                        <td>${formatAmount(row.feeAmount)}</td>
                        <td class="text-success">${formatAmount(row.clearedAmount)}</td>
                        <td class="text-danger">${formatAmount(row.pendingAmount)}</td>
                        <td>${statusBadge}</td>
                        <td>${row.remarks || '-'}</td>
                        <td>${deleteBtn}</td>
                    </tr>`;
            });

            tbody.html(rows);  // ← sirf ek baar DOM touch hoga

            updateSummary(data);
            $('#recordCount').text(`(${data.length} records)`);
        }
        // ── Delete ────────────────────────────────────────────────────
        function openDeleteModal(vid, studentName, feeTypeName) {
            deleteVID = vid;
            $('#deleteStudentName').text(studentName);
            $('#deleteFeeType').text(feeTypeName);
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }

        async function confirmDelete() {
            if (!deleteVID) return;
            $('#btnConfirmDelete').prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span> Deleting...');

            try {
                const response = await fetch(`${API_BASE}/ApplyFee/${deleteVID}`, { method: 'DELETE' });

                if (response.ok) {
                    bootstrap.Modal.getInstance(document.getElementById('deleteModal')).hide();
                    toastSuccess('Record deleted successfully');
                    loadList();
                } else {
                    toastError(await response.text() || 'Failed to delete record');
                }
            } catch (err) {
                toastError('Error deleting record');
            } finally {
                $('#btnConfirmDelete').prop('disabled', false).html('<i class="bi bi-trash me-1"></i> Delete');
                deleteVID = null;
            }
        }

        // ── Summary ───────────────────────────────────────────────────
        function updateSummary(data) {
            const totalFee     = data.reduce((sum, r) => sum + (r.feeAmount     || 0), 0);
            const totalCleared = data.reduce((sum, r) => sum + (r.clearedAmount || 0), 0);
            const totalPending = data.reduce((sum, r) => sum + (r.pendingAmount || 0), 0);

            $('#totalRecords').text(data.length);
            $('#totalFee').text(formatAmount(totalFee));
            $('#totalCleared').text(formatAmount(totalCleared));
            $('#totalPending').text(formatAmount(totalPending));
            $('#summaryCards').css('display', data.length > 0 ? 'flex' : 'none');
        }

        // ── Clear Filters ─────────────────────────────────────────────
        function clearFilters() {
            const now = new Date();
            monthPicker.clear();
            setTimeout(() => monthPicker.setDate([now, now], false), 10);

            $('#filterClass').val('');
            $('#filterSection').val('').prop('disabled', true);
            $('#filterRollNo').find('option:not(:first)').remove();
            $('#filterStudent').find('option:not(:first)').remove();
            $('#filterGrade').val('');
            $('#filterFeeType').val('');
            $('#clientSearch').val('');
            $('#clientStatus').val('');
            $('input[name="listChoice"][value="student"]').prop('checked', true);
            toggleChoiceFields();
            allData = [];
            renderList([]);
        }

        // ── Helpers ───────────────────────────────────────────────────
        function formatDate(d) {
            const yyyy = d.getFullYear();
            const mm   = String(d.getMonth() + 1).padStart(2, '0');
            const dd   = String(d.getDate()).padStart(2, '0');
            return `${yyyy}-${mm}-${dd}`;
        }

        function formatAmount(val) {
            return (val || 0).toLocaleString('en-PK', { minimumFractionDigits: 0 });
        }
    </script>
}