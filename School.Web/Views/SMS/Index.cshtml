        function previewExcelFile() {
            const fileInput = $('#excelFile')[0];
            if (!fileInput.files || !fileInput.files[0]) return;
            const file = fileInput.files[0];
            const reader = new FileReader();
            reader.onload = function (e) {
                try {
                    const data     = new Uint8Array(e.target.result);
                    const workbook = XLSX.read(data, { type: 'array' });
                    const sheet    = workbook.Sheets[workbook.SheetNames[0]];
                    excelParsedData = XLSX.utils.sheet_to_json(sheet, { defval: '' });
                    excelHeaders    = excelParsedData.length > 0 ? Object.keys(excelParsedData[0]) : [];

                    if (excelParsedData.length === 0) { toastWarning('Excel file is empty or has no data rows'); clearExcelForm(); return; }

                    $('#excelFileName').text(file.name);
                    $('#excelRowCount').text(excelParsedData.length + ' rows');
                    $('#excelPreviewSection').show();

                    const phoneSelect   = $('#excelPhoneColumn');
                    const messageSelect = $('#excelMessageColumn');
                    phoneSelect.find('option:not(:first)').remove();
                    messageSelect.find('option:not(:first)').remove();
                    excelHeaders.forEach(col => {
                        phoneSelect.append(`<option value="${col}">${col}</option>`);
                        messageSelect.append(`<option value="${col}">${col}</option>`);
                    });

                    // Auto-select common column names
                    autoSelectColumn(phoneSelect,   ['phone','mobile','contact','number','mobileno','phoneno','cell']);
                    autoSelectColumn(messageSelect, ['message','msg','text','sms','content']);

                    $('#excelColumnsSection').show();
                    renderExcelPreviewTable();
                    toastSuccess(`File loaded: ${excelParsedData.length} rows found`);
                } catch (err) { console.error(err); toastError('Failed to read Excel file. Make sure it is a valid .xlsx, .xls or .csv file.'); }
            };
            reader.readAsArrayBuffer(file);
        }

        function autoSelectColumn(selectElement, keywords) {
            selectElement.find('option').each(function () {
                if (keywords.some(k => $(this).val().toLowerCase().replace(/\s/g, '').includes(k))) {
                    selectElement.val($(this).val());
                    return false;
                }
            });
        }

        function renderExcelPreviewTable() {
            $('#excelPreviewTable').remove();
            if (!excelParsedData.length || !excelHeaders.length) return;
            const rows = excelParsedData.slice(0, 5);
            let html = `<div id="excelPreviewTable" class="mt-3"><label class="form-label fw-semibold">Data Preview (first 5 rows)</label><div class="table-responsive"><table class="table table-sm table-bordered" style="font-size:12px;"><thead style="background:#e2e8f0;"><tr>`;
            excelHeaders.forEach(h => html += `<th>${h}</th>`);
            html += `</tr></thead><tbody>`;
            rows.forEach(row => { html += '<tr>'; excelHeaders.forEach(h => { html += `<td>${row[h] ?? ''}</td>`; }); html += '</tr>'; });
            html += `</tbody></table></div></div>`;
            $('#excelColumnsSection').after(html);
        }

        async function sendExcelSMS() {
            if (!$('#excelFile').val())              { toastWarning('Please upload an Excel file'); return; }
            const phoneCol   = $('#excelPhoneColumn').val();
            const messageCol = $('#excelMessageColumn').val();
            if (!phoneCol)                           { toastWarning('Please select the Phone column'); return; }
            if (!messageCol)                         { toastWarning('Please select the Message column'); return; }
            if (excelParsedData.length === 0)        { toastWarning('No data found in Excel file'); return; }

            const recipients = [];
            const skipped    = [];

            excelParsedData.forEach((row, i) => {
                const rawPhone   = String(row[phoneCol]  ?? '').trim();
                const rawMessage = String(row[messageCol] ?? '').trim();
                const name       = String(row['Name'] ?? row['name'] ?? row['StudentName'] ?? `Row ${i + 2}`).trim();
                if (!rawPhone)   { skipped.push(`Row ${i + 2}: empty phone`);   return; }
                if (!rawMessage) { skipped.push(`Row ${i + 2}: empty message`); return; }
                const phone = normalizePhone(rawPhone);
                if (!phone)      { skipped.push(`Row ${i + 2}: invalid phone "${rawPhone}"`); return; }
                recipients.push({ phone, name, message: rawMessage });
            });

            if (recipients.length === 0) { toastWarning('No valid recipients found. Check phone and message columns.'); return; }

            if (skipped.length > 0)
                logSMS('excelSendingLog', 'excelSentCount', `⚠️ Skipped ${skipped.length} rows: ${skipped.slice(0, 3).join(', ')}${skipped.length > 3 ? '...' : ''}`);

            logSMS('excelSendingLog', 'excelSentCount', `📤 Sending to ${recipients.length} recipients...`);

            try {
                const response = await fetch(`${API_BASE}/Sms/send`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ recipients, message: '', messageType: 8 })
                });
                if (!response.ok) { const err = await response.json().catch(() => ({ message: 'Send failed' })); toastError(err.message || 'Failed to send SMS'); return; }
                const result = await response.json();
                logSMS('excelSendingLog', 'excelSentCount', `✅ Sent: ${result.totalSent} | ❌ Failed: ${result.totalFailed}`);
                result.totalFailed > 0 ? toastWarning(`${result.totalSent} sent, ${result.totalFailed} failed`) : toastSuccess(`${result.totalSent} messages sent successfully!`);
            } catch (ex) { console.error(ex); toastError('Network error while sending SMS'); }
        }

        function normalizePhone(raw) {
            let d = raw.replace(/\D/g, '');
            if (!d) return null;
            if (d.startsWith('92') && d.length === 12) return d;
            if (d.startsWith('0')  && d.length === 11) return '92' + d.substring(1);
            if (d.length === 10    && d.startsWith('3')) return '92' + d;
            return d.length >= 10 ? d : null;
        }

        function clearExcelForm() {
            $('#excelFile').val('');
            $('#excelPreviewSection').hide();
            $('#excelColumnsSection').hide();
            $('#excelPreviewTable').remove();
            $('#excelSmsUrdu').prop('checked', false);
            $('#excelSendingLog').val('');
            $('#excelSentCount').text('0');
            excelParsedData = [];
            excelHeaders    = [];
        }

