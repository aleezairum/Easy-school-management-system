@{
    ViewData["Title"] = "Role Permissions";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    .card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
        margin-bottom: 24px;
    }

    .card-header {
        background: white;
        border-bottom: 1px solid #e2e8f0;
        padding: 20px 24px;
        border-radius: 16px 16px 0 0 !important;
    }

    .card-header h5 {
        margin: 0;
        font-weight: 600;
        color: #1e293b;
    }

    .card-body {
        padding: 24px;
    }

    .form-label {
        font-weight: 500;
        color: #475569;
        margin-bottom: 8px;
        font-size: 14px;
    }

    .form-control, .form-select {
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 14px;
        transition: all 0.2s;
    }

    .form-control:focus, .form-select:focus {
        border-color: #008649;
        box-shadow: 0 0 0 4px rgba(0, 134, 73, 0.1);
    }

    .form-check-input {
        width: 18px;
        height: 18px;
        border: 2px solid #cbd5e1;
        border-radius: 4px;
        cursor: pointer;
    }

    .form-check-input:checked {
        background-color: #008649;
        border-color: #008649;
    }

    .form-check-input:focus {
        box-shadow: 0 0 0 4px rgba(0, 134, 73, 0.1);
    }

    .btn-primary {
        background: linear-gradient(135deg, #008649 0%, #006d3b 100%);
        border: none;
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 600;
        font-size: 14px;
        transition: all 0.2s;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(0, 134, 73, 0.4);
        background: linear-gradient(135deg, #006d3b 0%, #005a30 100%);
    }

    .btn-secondary {
        background: #f1f5f9;
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 600;
        font-size: 14px;
        color: #64748b;
        transition: all 0.2s;
    }

    .btn-secondary:hover {
        background: #e2e8f0;
        border-color: #cbd5e1;
        color: #475569;
    }

    .btn-info {
        background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
        border: none;
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 600;
        font-size: 14px;
        color: white;
        transition: all 0.2s;
    }

    .btn-info:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(14, 165, 233, 0.4);
    }

    .btn-warning {
        background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
        border: none;
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 600;
        font-size: 14px;
        color: white;
        transition: all 0.2s;
    }

    .btn-warning:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(245, 158, 11, 0.4);
    }

    .btn-danger {
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        border: none;
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 600;
        font-size: 14px;
        color: white;
        transition: all 0.2s;
    }

    .btn-danger:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.4);
        color: white;
    }

    .table {
        margin-bottom: 0;
    }

    .table thead th {
        background: #f8fafc;
        border-bottom: 2px solid #e2e8f0;
        padding: 14px 16px;
        font-weight: 600;
        font-size: 13px;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        white-space: nowrap;
    }

    .table tbody td {
        padding: 12px 16px;
        vertical-align: middle;
        border-bottom: 1px solid #f1f5f9;
        font-size: 14px;
    }

    .table tbody tr:hover {
        background: #f8fafc;
    }

    .menu-title {
        font-weight: 500;
        color: #1e293b;
    }

    .menu-title.child {
        color: #64748b;
        padding-left: 10px;
    }

    .alert {
        border-radius: 12px;
        border: none;
        padding: 16px 20px;
    }

    .alert-success {
        background: #dcfce7;
        color: #166534;
    }

    .alert-danger {
        background: #fee2e2;
        color: #991b1b;
    }

    .permission-grid {
        max-height: 500px;
        overflow-y: auto;
    }

    .permission-grid::-webkit-scrollbar {
        width: 8px;
    }

    .permission-grid::-webkit-scrollbar-track {
        background: #f1f5f9;
        border-radius: 4px;
    }

    .permission-grid::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 4px;
    }

    .permission-grid::-webkit-scrollbar-thumb:hover {
        background: #94a3b8;
    }

    .check-all-header {
        cursor: pointer;
        user-select: none;
    }

    .check-all-header:hover {
        color: #008649;
    }

    .loading-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255, 255, 255, 0.8);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 100;
        border-radius: 16px;
    }

    .spinner-border {
        width: 3rem;
        height: 3rem;
        border-width: 0.3rem;
    }

    .role-form-section {
        background: #f8fafc;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 20px;
    }
</style>

<div class="container-fluid">
    <!-- Alert Messages -->
    <div id="alertContainer"></div>

    <!-- Role List Card -->
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5><i class="bi bi-shield-lock me-2"></i>Role Permissions</h5>
            <button type="button" class="btn btn-primary" onclick="openAddModal()">
                <i class="bi bi-plus-lg me-1"></i> Add Role
            </button>
        </div>
        <div class="card-body position-relative">
            <div id="loadingOverlay" class="loading-overlay" style="display: none;">
                <div class="spinner-border text-success" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>

            <!-- Roles List Table -->
            <div class="table-responsive">
                <table class="table table-hover" id="rolesTable">
                    <thead>
                        <tr>
                            <th style="width: 60px;">Sr#</th>
                            <th>Role Name</th>
                            <th class="text-center" style="width: 100px;">Status</th>
                            <th class="text-center" style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="rolesBody">
                        <!-- Roles will be loaded dynamically -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Add Role Modal (Simple) -->
<div class="modal fade" id="addRoleModal" tabindex="-1" aria-labelledby="addRoleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius: 16px; border: none;">
            <div class="modal-header" style="border-bottom: 1px solid #e2e8f0;">
                <h5 class="modal-title" id="addRoleModalLabel"><i class="bi bi-plus-circle me-2"></i>Add Role</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addRoleForm">
                    <div class="mb-3">
                        <label for="newRoleName" class="form-label">Role Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="newRoleName" name="RoleName" placeholder="Enter role name" required />
                    </div>
                    <div class="mb-3">
                        <label for="newRoleDescription" class="form-label">Description</label>
                        <textarea class="form-control" id="newRoleDescription" name="Description" rows="2" placeholder="Enter role description"></textarea>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="newIsActive" name="IsActive" checked />
                        <label class="form-check-label" for="newIsActive">Is Active</label>
                    </div>
                </form>
            </div>
            <div class="modal-footer" style="border-top: 1px solid #e2e8f0;">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg me-1"></i> Cancel
                </button>
                <button type="button" class="btn btn-primary" onclick="saveNewRole()">
                    <i class="bi bi-check-lg me-1"></i> Save
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Role Permissions Modal -->
<div class="modal fade" id="permissionsModal" tabindex="-1" aria-labelledby="permissionsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content" style="border-radius: 16px; border: none;">
            <div class="modal-header" style="border-bottom: 1px solid #e2e8f0;">
                <h5 class="modal-title" id="permissionsModalLabel"><i class="bi bi-shield-lock me-2"></i>Edit Role Permissions</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="roleForm">
                    <input type="hidden" id="roleId" name="Id" value="0" />

                    <div class="role-form-section">
                        <div class="row g-3 align-items-end">
                            <div class="col-md-4">
                                <label for="roleName" class="form-label">Role Name <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="roleName" name="RoleName" placeholder="Enter role name" required />
                            </div>
                            <div class="col-md-6">
                                <label for="roleDescription" class="form-label">Description</label>
                                <input type="text" class="form-control" id="roleDescription" name="Description" placeholder="Enter description" />
                            </div>
                            <div class="col-md-2">
                                <div class="form-check mt-4">
                                    <input class="form-check-input" type="checkbox" id="isActive" name="IsActive" checked />
                                    <label class="form-check-label" for="isActive">Is Active</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Permissions Grid -->
                    <div class="table-responsive permission-grid">
                        <table class="table table-hover" id="permissionsTable">
                            <thead>
                                <tr>
                                    <th style="width: 60px;">Sr#</th>
                                    <th style="min-width: 250px;">Menu Title</th>
                                    <th class="text-center check-all-header" onclick="toggleColumn('IsView')" style="width: 80px;">
                                        IsView
                                        <br><small class="text-muted">(click all)</small>
                                    </th>
                                    <th class="text-center check-all-header" onclick="toggleColumn('IsInsert')" style="width: 80px;">
                                        IsInsert
                                        <br><small class="text-muted">(click all)</small>
                                    </th>
                                    <th class="text-center check-all-header" onclick="toggleColumn('IsUpdate')" style="width: 80px;">
                                        IsUpdate
                                        <br><small class="text-muted">(click all)</small>
                                    </th>
                                    <th class="text-center check-all-header" onclick="toggleColumn('IsDelete')" style="width: 80px;">
                                        IsDelete
                                        <br><small class="text-muted">(click all)</small>
                                    </th>
                                    <th class="text-center check-all-header" onclick="toggleColumn('IsActive')" style="width: 80px;">
                                        IsActive
                                        <br><small class="text-muted">(click all)</small>
                                    </th>
                                    <th class="text-center check-all-header" onclick="toggleColumn('IsBackDate')" style="width: 90px;">
                                        IsBackDate
                                        <br><small class="text-muted">(click all)</small>
                                    </th>
                                    <th class="text-center check-all-header" onclick="toggleColumn('IsPrint')" style="width: 80px;">
                                        IsPrint
                                        <br><small class="text-muted">(click all)</small>
                                    </th>
                                </tr>
                            </thead>
                            <tbody id="permissionsBody">
                                <!-- Permissions will be loaded dynamically -->
                            </tbody>
                        </table>
                    </div>
                </form>
            </div>
            <div class="modal-footer" style="border-top: 1px solid #e2e8f0;">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg me-1"></i> Cancel
                </button>
                <button type="button" class="btn btn-primary" onclick="saveRolePermissions()">
                    <i class="bi bi-check-lg me-1"></i> Save
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const API_BASE = 'http://localhost:5266/api';
        let allMenus = [];
        let currentPermissions = [];
        let addRoleModal = null;
        let permissionsModal = null;

        $(document).ready(function () {
            addRoleModal = new bootstrap.Modal(document.getElementById('addRoleModal'));
            permissionsModal = new bootstrap.Modal(document.getElementById('permissionsModal'));
            loadMenus();
            loadRoles();
        });

        // Load all roles for the list
        async function loadRoles() {
            showLoading();
            try {
                const response = await fetch(`${API_BASE}/RolesApi`);
                if (response.ok) {
                    const roles = await response.json();
                    renderRolesList(roles);
                } else {
                    showAlert('Failed to load roles', 'danger');
                }
            } catch (error) {
                console.error('Error loading roles:', error);
                showAlert('Error loading roles: ' + error.message, 'danger');
            } finally {
                hideLoading();
            }
        }

        // Render roles list table
        function renderRolesList(roles) {
            const tbody = $('#rolesBody');
            tbody.empty();

            if (roles.length === 0) {
                tbody.html('<tr><td colspan="4" class="text-center text-muted py-4">No roles found</td></tr>');
                return;
            }

            roles.forEach((role, index) => {
                const row = `
                    <tr>
                        <td>${index + 1}</td>
                        <td class="menu-title">${role.roleName}</td>
                        <td class="text-center">
                            <span class="badge ${role.isActive ? 'bg-success' : 'bg-secondary'}">${role.isActive ? 'Active' : 'Inactive'}</span>
                        </td>
                        <td class="text-center">
                            <button type="button" class="btn btn-sm btn-info me-1" onclick="editRole(${role.id})" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-danger" onclick="deleteRole(${role.id}, '${role.roleName}')" title="Delete">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                `;
                tbody.append(row);
            });
        }

        // Load all menus for the permissions grid
        async function loadMenus() {
            try {
                const response = await fetch(`${API_BASE}/MenusApi/hierarchy`);
                if (response.ok) {
                    allMenus = await response.json();
                } else {
                    showAlert('Failed to load menus', 'danger');
                }
            } catch (error) {
                console.error('Error loading menus:', error);
                showAlert('Error loading menus: ' + error.message, 'danger');
            }
        }

        // Open modal for adding a new role (simple modal without permissions)
        function openAddModal() {
            $('#newRoleName').val('');
            $('#newRoleDescription').val('');
            $('#newIsActive').prop('checked', true);
            addRoleModal.show();
        }

        // Save new role (simple add without permissions)
        async function saveNewRole() {
            const roleName = $('#newRoleName').val().trim();
            if (!roleName) {
                showAlert('Please enter a role name', 'danger');
                return;
            }

            const data = {
                roleName: roleName,
                description: $('#newRoleDescription').val().trim(),
                isActive: $('#newIsActive').is(':checked'),
                permissions: []
            };

            showLoading();
            try {
                const response = await fetch(`${API_BASE}/RolesApi/save`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(data)
                });

                if (response.ok) {
                    showAlert('Role created successfully!', 'success');
                    addRoleModal.hide();
                    await loadRoles();
                } else {
                    const error = await response.json();
                    showAlert(error.message || 'Failed to create role', 'danger');
                }
            } catch (error) {
                console.error('Error creating role:', error);
                showAlert('Error creating role: ' + error.message, 'danger');
            } finally {
                hideLoading();
            }
        }

        // Edit existing role (opens permissions modal)
        async function editRole(roleId) {
            showLoading();
            try {
                const response = await fetch(`${API_BASE}/RolesApi/${roleId}`);
                if (response.ok) {
                    const data = await response.json();
                    populateForm(data);
                    permissionsModal.show();
                } else {
                    showAlert('Failed to load role', 'danger');
                }
            } catch (error) {
                console.error('Error loading role:', error);
                showAlert('Error loading role: ' + error.message, 'danger');
            } finally {
                hideLoading();
            }
        }

        // Delete role
        async function deleteRole(roleId, roleName) {
            if (!confirm(`Are you sure you want to delete the role "${roleName}"?`)) {
                return;
            }

            showLoading();
            try {
                const response = await fetch(`${API_BASE}/RolesApi/${roleId}`, {
                    method: 'DELETE'
                });

                if (response.ok) {
                    showAlert('Role deleted successfully!', 'success');
                    await loadRoles();
                } else {
                    const error = await response.json();
                    showAlert(error.message || 'Failed to delete role', 'danger');
                }
            } catch (error) {
                console.error('Error deleting role:', error);
                showAlert('Error deleting role: ' + error.message, 'danger');
            } finally {
                hideLoading();
            }
        }

        // Render the permissions grid
        function renderPermissionsGrid(permissions = []) {
            const tbody = $('#permissionsBody');
            tbody.empty();

            allMenus.forEach((menu, index) => {
                const permission = permissions.find(p => p.menuId === menu.id) || {};
                const isChild = menu.menuTitle.startsWith('---->');
                const menuTitleClass = isChild ? 'menu-title child' : 'menu-title';

                const row = `
                    <tr data-menu-id="${menu.id}">
                        <td>${index + 1}</td>
                        <td class="${menuTitleClass}">${menu.menuTitle}</td>
                        <td class="text-center">
                            <input type="checkbox" class="form-check-input perm-checkbox"
                                   data-field="IsView" ${permission.isView ? 'checked' : ''} />
                        </td>
                        <td class="text-center">
                            <input type="checkbox" class="form-check-input perm-checkbox"
                                   data-field="IsInsert" ${permission.isInsert ? 'checked' : ''} />
                        </td>
                        <td class="text-center">
                            <input type="checkbox" class="form-check-input perm-checkbox"
                                   data-field="IsUpdate" ${permission.isUpdate ? 'checked' : ''} />
                        </td>
                        <td class="text-center">
                            <input type="checkbox" class="form-check-input perm-checkbox"
                                   data-field="IsDelete" ${permission.isDelete ? 'checked' : ''} />
                        </td>
                        <td class="text-center">
                            <input type="checkbox" class="form-check-input perm-checkbox"
                                   data-field="IsActive" ${permission.isActive ? 'checked' : ''} />
                        </td>
                        <td class="text-center">
                            <input type="checkbox" class="form-check-input perm-checkbox"
                                   data-field="IsBackDate" ${permission.isBackDate ? 'checked' : ''} />
                        </td>
                        <td class="text-center">
                            <input type="checkbox" class="form-check-input perm-checkbox"
                                   data-field="IsPrint" ${permission.isPrint ? 'checked' : ''} />
                        </td>
                    </tr>
                `;
                tbody.append(row);
            });
        }

        // Toggle all checkboxes in a column
        function toggleColumn(fieldName) {
            const checkboxes = $(`.perm-checkbox[data-field="${fieldName}"]`);
            const allChecked = checkboxes.filter(':checked').length === checkboxes.length;
            checkboxes.prop('checked', !allChecked);
        }

        // Populate form with role data (for permissions modal)
        function populateForm(data) {
            $('#roleId').val(data.id);
            $('#roleName').val(data.roleName);
            $('#roleDescription').val(data.description || '');
            $('#isActive').prop('checked', data.isActive);
            currentPermissions = data.permissions || [];
            renderPermissionsGrid(currentPermissions);
        }

        // Save role permissions
        async function saveRolePermissions() {
            const roleName = $('#roleName').val().trim();
            if (!roleName) {
                showAlert('Please enter a role name', 'danger');
                return;
            }

            // Collect permissions
            const permissions = [];
            $('#permissionsBody tr').each(function () {
                const row = $(this);
                const menuId = parseInt(row.data('menu-id'));

                permissions.push({
                    menuId: menuId,
                    isView: row.find('[data-field="IsView"]').is(':checked'),
                    isInsert: row.find('[data-field="IsInsert"]').is(':checked'),
                    isUpdate: row.find('[data-field="IsUpdate"]').is(':checked'),
                    isDelete: row.find('[data-field="IsDelete"]').is(':checked'),
                    isActive: row.find('[data-field="IsActive"]').is(':checked'),
                    isBackDate: row.find('[data-field="IsBackDate"]').is(':checked'),
                    isPrint: row.find('[data-field="IsPrint"]').is(':checked')
                });
            });

            const data = {
                id: parseInt($('#roleId').val()) || 0,
                roleName: roleName,
                description: $('#roleDescription').val().trim(),
                isActive: $('#isActive').is(':checked'),
                permissions: permissions
            };

            showLoading();
            try {
                const response = await fetch(`${API_BASE}/RolesApi/save`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(data)
                });

                if (response.ok) {
                    showAlert('Role permissions saved successfully!', 'success');
                    permissionsModal.hide();
                    await loadRoles();
                } else {
                    const error = await response.json();
                    showAlert(error.message || 'Failed to save role', 'danger');
                }
            } catch (error) {
                console.error('Error saving role:', error);
                showAlert('Error saving role: ' + error.message, 'danger');
            } finally {
                hideLoading();
            }
        }

        // Helper functions
        function showLoading() {
            $('#loadingOverlay').show();
        }

        function hideLoading() {
            $('#loadingOverlay').hide();
        }

        function showAlert(message, type) {
            const alert = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            `;
            $('#alertContainer').html(alert);

            // Auto-hide after 5 seconds
            setTimeout(() => {
                $('.alert').alert('close');
            }, 5000);
        }

        function hideAlert() {
            $('#alertContainer').empty();
        }
    </script>
}
