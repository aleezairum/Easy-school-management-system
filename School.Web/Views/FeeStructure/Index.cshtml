@{
    ViewData["Title"] = "Fee Structure";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    .card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
        margin-bottom: 24px;
    }

    .card-body {
        padding: 24px;
    }

    .form-label {
        font-weight: 500;
        color: #475569;
        margin-bottom: 8px;
        font-size: 14px;
    }

    .form-control {
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 14px;
        transition: all 0.2s;
    }

    .form-control:focus {
        border-color: #008649;
        box-shadow: 0 0 0 4px rgba(0, 134, 73, 0.1);
    }

    .form-check-input {
        width: 18px;
        height: 18px;
        border: 2px solid #cbd5e1;
        border-radius: 4px;
        cursor: pointer;
    }

    .form-check-input:checked {
        background-color: #008649;
        border-color: #008649;
    }

    .form-check-input:focus {
        box-shadow: 0 0 0 4px rgba(0, 134, 73, 0.1);
    }

    .btn-info {
        background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
        border: none;
        border-radius: 8px;
        padding: 6px 12px;
        font-weight: 600;
        font-size: 13px;
        color: white;
        transition: all 0.2s;
    }

    .btn-info:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(14, 165, 233, 0.4);
        color: white;
    }

    .btn-danger {
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        border: none;
        border-radius: 8px;
        padding: 6px 12px;
        font-weight: 600;
        font-size: 13px;
        color: white;
        transition: all 0.2s;
    }

    .btn-danger:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.4);
        color: white;
    }

    .table {
        margin-bottom: 0;
    }

    .table thead th {
        background: #f8fafc;
        border-bottom: 2px solid #e2e8f0;
        padding: 14px 16px;
        font-weight: 600;
        font-size: 13px;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        white-space: nowrap;
    }

    .table tbody td {
        padding: 12px 16px;
        vertical-align: middle;
        border-bottom: 1px solid #f1f5f9;
        font-size: 14px;
    }

    .table tbody tr:hover {
        background: #f8fafc;
    }

    .table tbody tr.selected {
        background: #ecfdf5;
        border-left: 3px solid #008649;
    }

    .loading-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255, 255, 255, 0.8);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 100;
        border-radius: 16px;
    }

    .spinner-border {
        width: 3rem;
        height: 3rem;
        border-width: 0.3rem;
    }

    .form-section {
        background: #f8fafc;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 20px;
    }

    .form-section-title {
        font-size: 14px;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 16px;
        padding-bottom: 8px;
        border-bottom: 2px solid #e2e8f0;
    }

    .filter-section {
        background: #f8fafc;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 20px;
    }

    .filter-section-title {
        font-size: 14px;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0;
        padding-bottom: 8px;
        border-bottom: 2px solid #e2e8f0;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: space-between;
        user-select: none;
    }

    .filter-section-title:hover {
        color: #008649;
    }

    .filter-section-title .chevron-icon {
        transition: transform 0.3s ease;
    }

    .filter-section-title.expanded .chevron-icon {
        transform: rotate(180deg);
    }

    .filter-collapse-body {
        padding-top: 16px;
    }

    .grid-section {
        margin-top: 24px;
    }

    .grid-section-title {
        font-size: 14px;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 16px;
        padding-bottom: 8px;
        border-bottom: 2px solid #e2e8f0;
    }

    /* Save Button */
    .btn-save {
        background-color: #00A651;
        color: white;
        font-weight: 600;
        font-size: 14px;
        padding: 12px 24px;
        border: none;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-save:hover {
        background-color: #008F45;
    }

    .btn-save:active {
        background-color: #007A3A;
        box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.15);
    }

    /* Clear Button */
    .btn-clear {
        background-color: transparent;
        color: #6B7280;
        font-weight: 600;
        font-size: 14px;
        padding: 12px 24px;
        border: 2px solid #D1D5DB;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-clear:hover {
        background-color: #F3F4F6;
        border-color: #9CA3AF;
    }

    .btn-clear:active {
        background-color: #E5E7EB;
    }
</style>

<div class="container-fluid">
    <div id="alertContainer"></div>

    <div class="card">
        <div class="card-body position-relative">
            <div id="loadingOverlay" class="loading-overlay" style="display: none;">
                <div class="spinner-border text-success" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>

            <!-- Form Section -->
            <div class="form-section">
                <div class="form-section-title">
                    <i class="bi bi-pencil-square me-2"></i><span id="formTitle">Add New Fee Structure</span>
                </div>
                <form id="feeStructureForm">
                    <input type="hidden" id="feeStructureId" value="0" />

                    <div class="row g-3 align-items-end">
                        <div class="col-md-3">
                            <label for="campusId" class="form-label">Campus <span class="text-danger">*</span></label>
                            <select class="form-select" id="campusId">
                                <option value="">-- Select Campus --</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="academicSessionId" class="form-label">Academic Session <span class="text-danger">*</span></label>
                            <select class="form-select" id="academicSessionId">
                                <option value="">-- Select Session --</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="classId" class="form-label">Class <span class="text-danger">*</span></label>
                            <select class="form-select" id="classId">
                                <option value="">-- Select Class --</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="gradeId" class="form-label">Grade</label>
                            <select class="form-select" id="gradeId">
                                <option value="">-- Select Grade --</option>
                            </select>
                        </div>
                    </div>

                    <div class="row g-3 align-items-end mt-1">
                        <div class="col-md-3">
                            <label for="feeTypeId" class="form-label">Fee Type <span class="text-danger">*</span></label>
                            <select class="form-select" id="feeTypeId">
                                <option value="">-- Select Fee Type --</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="amount" class="form-label">Amount <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="amount" placeholder="e.g., 5000" min="0" step="0.01" required />
                        </div>
                        <div class="col-md-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="isActive" checked />
                                <label class="form-check-label" for="isActive">Active</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="d-flex gap-2">
                                <button type="button" class="btn-save" onclick="saveFeeStructure()">
                                    <i class="bi bi-check-lg"></i> Save
                                </button>
                                <button type="button" class="btn-clear" onclick="resetForm()">
                                    <i class="bi bi-x-lg"></i> Clear
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Filter Section -->
            <div class="filter-section">
                <div class="filter-section-title" data-bs-toggle="collapse" data-bs-target="#filterCollapseBody">
                    <span><i class="bi bi-funnel me-2"></i>Search Filters</span>
                    <i class="bi bi-chevron-down chevron-icon"></i>
                </div>
                <div class="collapse" id="filterCollapseBody">
                    <div class="filter-collapse-body">
                        <div class="row g-3 align-items-end">
                            <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                                <label for="filterCampus" class="form-label">Campus</label>
                                <select class="form-select" id="filterCampus">
                                    <option value="">All Campuses</option>
                                </select>
                            </div>
                            <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                                <label for="filterSession" class="form-label">Academic Session</label>
                                <select class="form-select" id="filterSession">
                                    <option value="">All Sessions</option>
                                </select>
                            </div>
                            <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                                <label for="filterClass" class="form-label">Class</label>
                                <select class="form-select" id="filterClass">
                                    <option value="">All Classes</option>
                                </select>
                            </div>
                            <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                                <label for="filterGrade" class="form-label">Grade</label>
                                <select class="form-select" id="filterGrade">
                                    <option value="">All Grades</option>
                                </select>
                            </div>
                            <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                                <label for="filterFeeType" class="form-label">Fee Type</label>
                                <select class="form-select" id="filterFeeType">
                                    <option value="">All Fee Types</option>
                                </select>
                            </div>
                            <div class="col-lg-3 col-md-4 col-sm-6 col-12">
                                <label for="filterStatus" class="form-label">Status</label>
                                <select class="form-select" id="filterStatus">
                                    <option value="">All Status</option>
                                    <option value="true">Active</option>
                                    <option value="false">Inactive</option>
                                </select>
                            </div>
                        </div>
                        <div class="row mt-3">
                            <div class="col-12">
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn-save" onclick="loadFeeStructures()">
                                        <i class="bi bi-search"></i> Search
                                    </button>
                                    <button type="button" class="btn-clear" onclick="clearFilters()">
                                        <i class="bi bi-x-lg"></i> Clear
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Grid Section -->
            <div class="grid-section">
                <div class="grid-section-title">
                    <i class="bi bi-table me-2"></i>Fee Structures List
                </div>
                <div class="table-responsive">
                    <table class="table table-hover" id="feeStructuresTable">
                        <thead>
                            <tr>
                                <th style="width: 60px;">SR#</th>
                                <th>Campus</th>
                                <th>Academic Session</th>
                                <th>Class</th>
                                <th>Grade</th>
                                <th>Fee Type</th>
                                <th class="text-end">Amount</th>
                                <th class="text-center" style="width: 100px;">Status</th>
                                <th class="text-center" style="width: 150px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="feeStructuresBody">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let editingId = 0;

        $(document).ready(function () {
            loadDropdowns();
            loadFeeStructures();

            $('#filterCollapseBody').on('show.bs.collapse', function () {
                $('.filter-section-title').addClass('expanded');
            }).on('hide.bs.collapse', function () {
                $('.filter-section-title').removeClass('expanded');
            });
        });

        async function loadDropdowns() {
            try {
                const [campuses, sessions, classes, grades, feeTypes] = await Promise.all([
                    fetch(`${API_BASE}/campus`).then(r => r.json()).catch(() => []),
                    fetch(`${API_BASE}/AcademicSessionYear`).then(r => r.json()).catch(() => []),
                    fetch(`${API_BASE}/class`).then(r => r.json()).catch(() => []),
                    fetch(`${API_BASE}/AcademicGrade`).then(r => r.json()).catch(() => []),
                    fetch(`${API_BASE}/feetype`).then(r => r.json()).catch(() => [])
                ]);

                const campusSelect = $('#campusId');
                const filterCampus = $('#filterCampus');
                campuses.forEach(item => {
                    campusSelect.append(`<option value="${item.vid}">${item.vName}</option>`);
                    filterCampus.append(`<option value="${item.vid}">${item.vName}</option>`);
                });

                const sessionSelect = $('#academicSessionId');
                const filterSession = $('#filterSession');
                sessions.forEach(item => {
                    sessionSelect.append(`<option value="${item.vid}">${item.vName}</option>`);
                    filterSession.append(`<option value="${item.vid}">${item.vName}</option>`);
                });

                const classSelect = $('#classId');
                const filterClass = $('#filterClass');
                classes.forEach(item => {
                    classSelect.append(`<option value="${item.vid}">${item.vName}</option>`);
                    filterClass.append(`<option value="${item.vid}">${item.vName}</option>`);
                });

                const gradeSelect = $('#gradeId');
                const filterGrade = $('#filterGrade');
                grades.forEach(item => {
                    gradeSelect.append(`<option value="${item.id}">${item.name}</option>`);
                    filterGrade.append(`<option value="${item.id}">${item.name}</option>`);
                });

                const feeTypeSelect = $('#feeTypeId');
                const filterFeeType = $('#filterFeeType');
                feeTypes.forEach(item => {
                    feeTypeSelect.append(`<option value="${item.vid}">${item.vName}</option>`);
                    filterFeeType.append(`<option value="${item.vid}">${item.vName}</option>`);
                });
            } catch (error) {
                console.error('Error loading dropdowns:', error);
                showAlert('Error loading dropdowns: ' + error.message, 'danger');
            }
        }

        async function loadFeeStructures() {
            showLoading();
            try {
                const response = await fetch(`${API_BASE}/feestructure`);
                if (response.ok) {
                    let data = await response.json();

                    const filterCampusVal = $('#filterCampus').val();
                    const filterSessionVal = $('#filterSession').val();
                    const filterClassVal = $('#filterClass').val();
                    const filterGradeVal = $('#filterGrade').val();
                    const filterFeeTypeVal = $('#filterFeeType').val();
                    const filterStatusVal = $('#filterStatus').val();

                    if (filterCampusVal) {
                        data = data.filter(item => item.campusID && item.campusID.toString() === filterCampusVal);
                    }
                    if (filterSessionVal) {
                        data = data.filter(item => item.academicSessionID && item.academicSessionID.toString() === filterSessionVal);
                    }
                    if (filterClassVal) {
                        data = data.filter(item => item.classID && item.classID.toString() === filterClassVal);
                    }
                    if (filterGradeVal) {
                        data = data.filter(item => item.gradeID && item.gradeID.toString() === filterGradeVal);
                    }
                    if (filterFeeTypeVal) {
                        data = data.filter(item => item.feeTypeID && item.feeTypeID.toString() === filterFeeTypeVal);
                    }
                    if (filterStatusVal) {
                        data = data.filter(item => item.isActive.toString() === filterStatusVal);
                    }

                    renderList(data);
                } else {
                    showAlert('Failed to load fee structures', 'danger');
                }
            } catch (error) {
                console.error('Error loading fee structures:', error);
                showAlert('Error loading fee structures: ' + error.message, 'danger');
            } finally {
                hideLoading();
            }
        }

        function renderList(items) {
            const tbody = $('#feeStructuresBody');
            tbody.empty();

            if (items.length === 0) {
                tbody.html('<tr><td colspan="9" class="text-center text-muted py-4">No fee structures found. Add a new fee structure using the form above.</td></tr>');
                return;
            }

            items.forEach((item, index) => {
                const row = `
                    <tr data-id="${item.vid}" class="${editingId === item.vid ? 'selected' : ''}">
                        <td>${index + 1}</td>
                        <td>${item.campusName || ''}</td>
                        <td>${item.academicSessionName || ''}</td>
                        <td>${item.className || ''}</td>
                        <td>${item.gradeName || ''}</td>
                        <td>${item.feeTypeName || ''}</td>
                        <td class="text-end"><strong>${parseFloat(item.amount || 0).toLocaleString('en-US', { minimumFractionDigits: 2 })}</strong></td>
                        <td class="text-center">
                            <span class="badge ${item.isActive ? 'bg-success' : 'bg-secondary'}">
                                ${item.isActive ? 'Active' : 'Inactive'}
                            </span>
                        </td>
                        <td class="text-center">
                            <button type="button" class="btn btn-sm btn-info me-1" onclick="editFeeStructure(${item.vid})" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-danger" onclick="deleteFeeStructure(${item.vid})" title="Delete">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                `;
                tbody.append(row);
            });
        }

        async function editFeeStructure(id) {
            showLoading();
            try {
                const response = await fetch(`${API_BASE}/feestructure/${id}`);
                if (response.ok) {
                    const data = await response.json();
                    populateForm(data);
                    editingId = id;
                    $('#formTitle').text('Edit Fee Structure');

                    $('#feeStructuresBody tr').removeClass('selected');
                    $(`#feeStructuresBody tr[data-id="${id}"]`).addClass('selected');

                    $('html, body').animate({
                        scrollTop: $('.form-section').offset().top - 100
                    }, 300);
                } else {
                    showAlert('Failed to load fee structure', 'danger');
                }
            } catch (error) {
                console.error('Error loading fee structure:', error);
                showAlert('Error loading fee structure: ' + error.message, 'danger');
            } finally {
                hideLoading();
            }
        }

        async function deleteFeeStructure(id) {
            if (!confirm('Are you sure you want to delete this fee structure?')) {
                return;
            }

            showLoading();
            try {
                const response = await fetch(`${API_BASE}/feestructure/${id}`, {
                    method: 'DELETE'
                });

                if (response.ok) {
                    showAlert('Fee structure deleted successfully!', 'success');
                    if (editingId === id) {
                        resetForm();
                    }
                    await loadFeeStructures();
                } else {
                    const error = await response.json();
                    showAlert(error.message || 'Failed to delete fee structure', 'danger');
                }
            } catch (error) {
                console.error('Error deleting fee structure:', error);
                showAlert('Error deleting fee structure: ' + error.message, 'danger');
            } finally {
                hideLoading();
            }
        }

        function populateForm(data) {
            $('#feeStructureId').val(data.vid);
            $('#campusId').val(data.campusID).trigger('change');
            $('#academicSessionId').val(data.academicSessionID).trigger('change');
            $('#classId').val(data.classID).trigger('change');
            $('#gradeId').val(data.gradeID).trigger('change');
            $('#feeTypeId').val(data.feeTypeID).trigger('change');
            $('#amount').val(data.amount);
            $('#isActive').prop('checked', data.isActive);
        }

        function resetForm() {
            $('#feeStructureId').val('0');
            $('#campusId').val('').trigger('change');
            $('#academicSessionId').val('').trigger('change');
            $('#classId').val('').trigger('change');
            $('#gradeId').val('').trigger('change');
            $('#feeTypeId').val('').trigger('change');
            $('#amount').val('');
            $('#isActive').prop('checked', true);
            $('#formTitle').text('Add New Fee Structure');
            editingId = 0;
            $('#feeStructuresBody tr').removeClass('selected');
        }

        function clearFilters() {
            $('#filterCampus').val('').trigger('change');
            $('#filterSession').val('').trigger('change');
            $('#filterClass').val('').trigger('change');
            $('#filterGrade').val('').trigger('change');
            $('#filterFeeType').val('').trigger('change');
            $('#filterStatus').val('').trigger('change');
            loadFeeStructures();
        }

        async function saveFeeStructure() {
            const campusID = $('#campusId').val();
            const academicSessionID = $('#academicSessionId').val();
            const classID = $('#classId').val();
            const gradeID = $('#gradeId').val();
            const feeTypeID = $('#feeTypeId').val();
            const amount = $('#amount').val();

            if (!campusID) {
                showAlert('Please select a Campus', 'danger');
                $('#campusId').focus();
                return;
            }
            if (!academicSessionID) {
                showAlert('Please select an Academic Session', 'danger');
                $('#academicSessionId').focus();
                return;
            }
            if (!classID) {
                showAlert('Please select a Class', 'danger');
                $('#classId').focus();
                return;
            }
            if (!feeTypeID) {
                showAlert('Please select a Fee Type', 'danger');
                $('#feeTypeId').focus();
                return;
            }
            if (!amount || parseFloat(amount) <= 0) {
                showAlert('Please enter a valid amount', 'danger');
                $('#amount').focus();
                return;
            }

            const id = parseInt($('#feeStructureId').val()) || 0;
            const data = {
                VID: id,
                CampusID: parseInt(campusID),
                AcademicSessionID: parseInt(academicSessionID),
                ClassID: parseInt(classID),
                GradeID: gradeID ? parseInt(gradeID) : 0,
                FeeTypeID: parseInt(feeTypeID),
                Amount: parseFloat(amount),
                IsActive: $('#isActive').is(':checked')
            };

            showLoading();
            try {
                const response = await fetch(`${API_BASE}/feestructure`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                if (response.ok) {
                    showAlert(id === 0 ? 'Fee structure created successfully!' : 'Fee structure updated successfully!', 'success');
                    resetForm();
                    await loadFeeStructures();
                } else {
                    const error = await response.json();
                    showAlert(error.returnMessage || error.message || 'Failed to save fee structure', 'danger');
                }
            } catch (error) {
                console.error('Error saving fee structure:', error);
                showAlert('Error saving fee structure: ' + error.message, 'danger');
            } finally {
                hideLoading();
            }
        }

        function showLoading() {
            $('#loadingOverlay').show();
        }

        function hideLoading() {
            $('#loadingOverlay').hide();
        }

        function showAlert(message, type) {
            if (type === 'success') {
                toastSuccess(message);
            } else if (type === 'danger' || type === 'error') {
                toastError(message);
            } else if (type === 'warning') {
                toastWarning(message);
            } else {
                toastInfo(message);
            }
        }
    </script>
}
