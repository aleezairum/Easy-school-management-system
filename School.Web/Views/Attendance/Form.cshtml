@{
    ViewData["Title"] = "Mark Attendance";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <div id="alertContainer"></div>

    <div class="card" style="border-radius: 16px; border: none; box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
        <div class="card-body p-4 position-relative">
            <!-- Loading overlay -->
            <div id="loadingOverlay" class="loading-overlay" style="display: none;">
                <div class="spinner-border text-success" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
            <div class="d-flex justify-content-end mb-3">
                <a href="/attendance" class="btn btn-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Back to List
                </a>
            </div>
            <!-- Filter Section -->
            <div class="filter-section" style="background: #f8fafc; border-radius: 12px; padding: 20px; margin-bottom: 20px;">
                <div class="row g-3 align-items-end">
                    <div class="col-lg-2 col-md-3 col-sm-6 col-12">
                        <label for="classId" class="form-label">Class <span class="text-danger">*</span></label>
                        <select class="form-select" id="classId" required onchange="loadSections()">
                            <option value="">-- Select Class --</option>
                        </select>
                    </div>
                    <div class="col-lg-2 col-md-3 col-sm-6 col-12">
                        <label for="sectionId" class="form-label">Section <span class="text-danger">*</span></label>
                        <select class="form-select" id="sectionId" required disabled onchange="loadStudents()">
                            <option value="">-- Select Section --</option>
                        </select>
                    </div>
                    <div class="col-lg-2 col-md-3 col-sm-6 col-12">
                        <label for="attendanceDate" class="form-label">Date <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" id="attendanceDate" required />
                    </div>
                    <div class="col-lg-1 col-md-3 col-sm-6 col-12">
                        <label class="form-label">Total</label>
                        <input type="text" class="form-control" id="totalStudents" readonly value="0" style="background-color: #e2e8f0; font-weight: 600; text-align: center;" />
                    </div>
                    <div class="col-lg-1 col-md-3 col-sm-6 col-12">
                        <label class="form-label text-success">Present</label>
                        <input type="text" class="form-control" id="totalPresent" readonly value="0" style="background-color: #dcfce7; color: #16a34a; font-weight: 600; text-align: center;" />
                    </div>
                    <div class="col-lg-1 col-md-3 col-sm-6 col-12">
                        <label class="form-label text-danger">Absent</label>
                        <input type="text" class="form-control" id="totalAbsent" readonly value="0" style="background-color: #fee2e2; color: #dc2626; font-weight: 600; text-align: center;" />
                    </div>
                    <div class="col-lg-1 col-md-3 col-sm-6 col-12">
                        <label class="form-label text-info">Leave</label>
                        <input type="text" class="form-control" id="totalLeave" readonly value="0" style="background-color: #e0f2fe; color: #0284c7; font-weight: 600; text-align: center;" />
                    </div>
                    <div class="col-lg-2 col-md-3 col-sm-6 col-12 d-flex align-items-end gap-2">
                        <button type="button" class="btn btn-primary" onclick="loadStudents()">
                            <i class="bi bi-search me-1"></i> Load Students
                        </button>
                    </div>
                </div>
                <!-- Action Buttons -->
                <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                    <a href="/attendance" class="btn btn-secondary">
                        <i class="bi bi-x-lg me-1"></i> Close
                    </a>
                    @* <button type="button" class="btn btn-primary" onclick="printAttendance()">
                    <i class="bi bi-printer me-1"></i> Print
                </button>
                <button type="button" class="btn btn-primary" onclick="printAttendanceReport()">
                    <i class="bi bi-file-earmark-text me-1"></i> Print Report
                </button> *@
                    <button type="button" class="btn btn-primary" id="btnSave" onclick="saveAttendance()">
                        <i class="bi bi-check-lg me-1"></i> Save
                    </button>
            </div>

            <!-- Attendance Grid -->
            <div class="grid-section">
                <div class="table-responsive">
                    <table class="table table-hover" id="attendanceTable">
                        <thead>
                            <tr style="background: #f8fafc;">
                                <th>Roll No</th>
                                <th>Student Name</th>
                                <th class="text-center">Attendance <i class="bi bi-check-all" onclick="markAllPresent()" title="Mark All Present" style="cursor: pointer; color: #16a34a; font-size: 18px; margin-left: 4px;"></i></th>
                                <th class="text-center">Late</th>
                                <th class="text-center">Again</th>
                            </tr>
                        </thead>
                        <tbody id="attendanceBody">
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">Select Class and Section to load students</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            
            </div>
        </div>
    </div>
</div>

@section Styles {
<style>
    .loading-overlay { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(255,255,255,0.8); display: flex; align-items: center; justify-content: center; z-index: 100; border-radius: 16px; }
    .spinner-border { width: 3rem; height: 3rem; border-width: 0.3rem; }
    .btn-outline-leave { border: 1px solid #2563eb; color: #2563eb; background: transparent; }
    .btn-outline-leave:hover { background: #2563eb; color: white; }
    .form-check-input:checked { background-color: #008649; border-color: #008649; }
    .form-check-input:focus { box-shadow: 0 0 0 0.25rem rgba(0,134,73,0.25); border-color: #008649; }
    .attendance-btn.btn-success, .attendance-btn.btn-success:hover, .attendance-btn.btn-success:focus { background: linear-gradient(135deg, #008649 0%, #006d3b 100%); border-color: #008649; color: white; }
    .attendance-btn.btn-danger, .attendance-btn.btn-danger:hover, .attendance-btn.btn-danger:focus { background: #dc2626; border-color: #dc2626; color: white; }
    .attendance-btn.btn-leave, .attendance-btn.btn-leave:hover, .attendance-btn.btn-leave:focus { background: #2563eb; border-color: #2563eb; color: white; }
    @@media (max-width: 767px) {
        .btn-group .btn {
            min-width: 40px;
            min-height: 40px;
            padding: 8px;
        }
        .form-check {
            min-height: 40px;
            display: flex;
            align-items: center;
        }
    }
</style>
}

@section Scripts {
    <script>
                let allStudents = [];
        let sessionId = null;

        $(document).ready(function () {
            $('#attendanceDate').val(new Date().toISOString().split('T')[0]);
            loadClasses();
            loadActiveSession();
        });

        async function loadActiveSession() {
            try {
                const response = await fetch(`${API_BASE}/AcademicSessionYear`);
                if (response.ok) {
                    const sessions = await response.json();
                    if (sessions.length > 0) sessionId = sessions[0].vid;
                }
            } catch (error) {
                console.error('Error loading session:', error);
            }
        }

        async function loadClasses() {
            try {
                const response = await fetch(`${API_BASE}/class`);
                if (response.ok) {
                    const classes = await response.json();
                    const select = $('#classId');
                    select.find('option:not(:first)').remove();
                    classes.forEach(c => {
                        select.append(`<option value="${c.vid}">${c.vName}</option>`);
                    });
                }
            } catch (error) {
                toastError('Error loading classes');
            }
        }

        async function loadSections() {
            const classId = $('#classId').val();
            const sectionSelect = $('#sectionId');
            sectionSelect.find('option:not(:first)').remove();
            sectionSelect.prop('disabled', true);
            allStudents = [];
            renderGrid([]);

            if (!classId) return;

            try {
                const response = await fetch(`${API_BASE}/section/byClass/${classId}`);
                if (response.ok) {
                    const sections = await response.json();
                    sections.forEach(s => {
                        sectionSelect.append(`<option value="${s.vid}">${s.vName}</option>`);
                    });
                    sectionSelect.prop('disabled', false);
                }
            } catch (error) {
                toastError('Error loading sections');
            }
        }

        async function loadStudents() {
            const classId   = $('#classId').val();
            const sectionId = $('#sectionId').val();
            const date      = $('#attendanceDate').val();

            if (!classId)   { toastWarning('Please select a Class');   return; }
            if (!sectionId) { toastWarning('Please select a Section'); return; }
            if (!date)      { toastWarning('Please select a Date');    return; }
            if (!sessionId) { toastWarning('No active session found'); return; }

            showLoading();
            try {
                // Step 1: Load all students
                const studentsRes = await fetch(`${API_BASE}/Student`);
                if (!studentsRes.ok) { toastError('Failed to fetch students'); return; }
                const students = await studentsRes.json();

                // Step 2: Filter by class, section, active
                allStudents = students.filter(s => {
                    const matchClass   = String(s.classID   || s.classId   || '') === String(classId);
                    const matchSection = String(s.sectionID || s.sectionId || '') === String(sectionId);
                    return matchClass && matchSection && s.isActive === true && s.statusID === 1;
                });

                allStudents.sort((a, b) => (parseInt(a.rollNo) || 0) - (parseInt(b.rollNo) || 0));

                // Step 3: Check if today's attendance already exists
                const params = new URLSearchParams({
                    SessionID: sessionId,
                    SectionID: sectionId,
                    DateFrom:  date,
                    DateTo:    date
                });

                const attRes = await fetch(`${API_BASE}/StdAttendence?${params.toString()}`);
                const existingAttendance = attRes.ok ? await attRes.json() : [];

                // Step 4: Map existing attendance to students
                allStudents.forEach(s => {
                    const sid      = s.vid || s.id;
                    // FIX 1: match by studentID field from SP result
                    const existing = existingAttendance.find(
                        a => a.studentID === sid || a.studentId === sid
                    );

                    if (existing) {
                        // Pre-fill from existing record
                        //  FIX 2: correctly map attendence value 
                        if      (existing.attendence === 1 ) s.attendance = 'P';
                        else if (existing.attendence === 0 ) s.attendance = 'A';
                        else if (existing.attendence === 2 ) s.attendance = 'L';
                        else                                 s.attendance = 'A';

                        s.late    = existing.isLate  || false;
                        s.again   = existing.isAgain || false;
                        s.vid_att = existing.vID;      // store attendance VID for update
                    } else {
                        // Fresh — default to Present
                        s.attendance = 'P';
                        s.late       = false;
                        s.again      = false;
                        s.vid_att    = 0;
                    }
                });

                renderGrid(allStudents);

                // Show message based on whether attendance exists
                const hasExisting = existingAttendance.length > 0;
                if (allStudents.length === 0) {
                    toastInfo('No students found');
                } else if (hasExisting) {
                    toastInfo(`Attendance already marked — loaded for editing`);
                } else {
                    toastSuccess(`${allStudents.length} student(s) loaded`);
                }

            } catch (error) {
                toastError('Error: ' + error.message);
            } finally {
                hideLoading();
            }
        }

        function renderGrid(studentList) {
            const tbody = $('#attendanceBody');
            tbody.empty();

            if (studentList.length === 0) {
                tbody.html('<tr><td colspan="5" class="text-center text-muted py-4">Select Class and Section to load students</td></tr>');
                $('#totalStudents').val(0);
                updateCounts();
                return;
            }

            $('#totalStudents').val(studentList.length);

            studentList.forEach((student, index) => {
                const sid = student.vid || student.id;
                const att = student.attendance || 'P';

                const pActive = att === 'P' ? 'active btn-success text-white'     : '';
                const aActive = att === 'A' ? 'active btn-danger text-white'      : '';
                const lActive = att === 'L' ? 'active btn-leave text-white'       : '';

                // Late/Again disabled if not Present
                const checkDisabled = att !== 'P' ? 'disabled' : '';

                const row = `
                    <tr data-student-id="${sid}">
                        <td><strong>${student.rollNo || index + 1}</strong></td>
                        <td>${student.studentName || student.name || '-'}</td>
                        <td class="text-center">
                            <div class="btn-group" role="group">
                                <button type="button"
                                    class="btn btn-sm btn-outline-success attendance-btn ${pActive}"
                                    onclick="setAttendance(${sid}, 'P', this)" data-value="P">P</button>
                                <button type="button"
                                    class="btn btn-sm btn-outline-danger attendance-btn ${aActive}"
                                    onclick="setAttendance(${sid}, 'A', this)" data-value="A">A</button>
                                <button type="button"
                                    class="btn btn-sm btn-outline-leave attendance-btn ${lActive}"
                                    onclick="setAttendance(${sid}, 'L', this)" data-value="L">L</button>
                            </div>
                        </td>
                        <td class="text-center">
                            <input type="checkbox" class="form-check-input late-checkbox"
                                data-student-id="${sid}"
                                ${student.late    ? 'checked'  : ''}
                                ${checkDisabled}
                                onchange="updateLate(${sid}, this.checked)" />
                        </td>
                        <td class="text-center">
                            <input type="checkbox" class="form-check-input again-checkbox"
                                data-student-id="${sid}"
                                ${student.again   ? 'checked'  : ''}
                                ${checkDisabled}
                                onchange="updateAgain(${sid}, this.checked)" />
                        </td>
                    </tr>
                `;
                tbody.append(row);
            });

            updateCounts();
        }

        function setAttendance(studentId, value, button) {
            const student = allStudents.find(s => (s.vid || s.id) === studentId);
            if (student) student.attendance = value;

            const btnGroup = $(button).closest('.btn-group');
            btnGroup.find('.attendance-btn').removeClass('active btn-success btn-danger btn-leave text-white');
            $(button).addClass('active text-white');
            if      (value === 'P') $(button).addClass('btn-success');
            else if (value === 'A') $(button).addClass('btn-danger');
            else if (value === 'L') $(button).addClass('btn-leave');

            const row = $(button).closest('tr');
            if (value === 'P') {
                row.find('.late-checkbox, .again-checkbox').prop('disabled', false);
            } else {
                row.find('.late-checkbox, .again-checkbox').prop('checked', false).prop('disabled', true);
                if (student) { student.late = false; student.again = false; }
            }

            updateCounts();
        }

        function updateLate(studentId, isLate) {
            const student = allStudents.find(s => (s.vid || s.id) === studentId);
            if (student) student.late = isLate;
        }

        function updateAgain(studentId, isAgain) {
            const student = allStudents.find(s => (s.vid || s.id) === studentId);
            if (student) student.again = isAgain;
        }

        function updateCounts() {
            $('#totalPresent').val(allStudents.filter(s => s.attendance === 'P').length);
            $('#totalAbsent').val(allStudents.filter(s => s.attendance === 'A').length);
            $('#totalLeave').val(allStudents.filter(s => s.attendance === 'L').length);
        }

        function markAllPresent() {
            if (allStudents.length === 0) { toastWarning('Load students first'); return; }

            allStudents.forEach(s => { s.attendance = 'P'; s.late = false; s.again = false; });

            $('#attendanceBody tr').each(function () {
                const btnGroup = $(this).find('.btn-group');
                btnGroup.find('.attendance-btn').removeClass('active btn-success btn-danger btn-leave text-white');
                btnGroup.find('.attendance-btn[data-value="P"]').addClass('active btn-success text-white');
                $(this).find('.late-checkbox, .again-checkbox')
                       .prop('checked', false)
                       .prop('disabled', false);
            });

            updateCounts();
            toastSuccess('All students marked as Present');
        }

        async function saveAttendance() {
            const classId   = $('#classId').val();
            const sectionId = $('#sectionId').val();
            const date      = $('#attendanceDate').val();

            if (!classId || !sectionId || !date) {
                toastWarning('Please select Class, Section and Date');
                return;
            }
            if (!sessionId) { toastWarning('No active session found'); return; }
            if (allStudents.length === 0) { toastWarning('No students loaded'); return; }

            //  FIX 3: correctly map P/A/L to attendence value 
            const payload = allStudents.map(s => ({
                vID:        s.vid_att || 0,
                sessionID:  sessionId,
                studentID:  s.vid || s.id,
                sectionID:  parseInt(sectionId),
                vDate:      date,
                attendence: s.attendance === 'P' ? 1
                          : s.attendance === 'L' ? 2
                          : 0,                          // A = 0, P = 1, L = 2
                isLate:    s.late  || false,
                isAgain:   s.again || false,
                remarks:   s.attendance === 'L' ? 'Leave' : null,
                iSentSMS:  false
            }));

            showLoading();
            try {
                const results = await Promise.all(
                    payload.map(dto =>
                        fetch(`${API_BASE}/StdAttendence`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(dto)
                        }).then(r => r.json())
                    )
                );

                const failed = results.filter(r => r.returnCode !== 200);
                if (failed.length === 0) {
                    toastSuccess('Attendance saved successfully!');
                } else {
                    toastWarning(`${failed.length} record(s) failed`);
                    console.warn('Failed:', failed);
                }
            } catch (error) {
                toastError('Error saving attendance: ' + error.message);
            } finally {
                hideLoading();
            }
        }

        function printAttendance() { window.print(); }

        function printAttendanceReport() {
            const classId   = $('#classId').val();
            const sectionId = $('#sectionId').val();
            const date      = $('#attendanceDate').val();

            if (classId && sectionId && date) {
                window.open(`/attendance/report?classId=${classId}&sectionId=${sectionId}&date=${date}`, '_blank');
            } else {
                toastWarning('Please select Class, Section and Date first');
            }
        }

        function showLoading() { $('#loadingOverlay').css('display', 'flex'); }
        function hideLoading() { $('#loadingOverlay').css('display', 'none'); }
    </script>
}