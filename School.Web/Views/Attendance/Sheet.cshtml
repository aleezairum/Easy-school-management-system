@{
    ViewData["Title"] = "Attendance Sheet";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
<style>
    /* Card */
    .card { border: none; border-radius: 16px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); margin-bottom: 24px; }
    .card-header { background: white; border-bottom: 1px solid #e2e8f0; padding: 20px 24px; border-radius: 16px 16px 0 0 !important; }
    .card-header h5 { margin: 0; font-weight: 600; color: #1e293b; }
    .card-body { padding: 24px; }

    /* Form controls */
    .form-label { font-weight: 500; color: #475569; margin-bottom: 8px; font-size: 14px; }
    .form-control, .form-select { border: 2px solid #e2e8f0; border-radius: 10px; padding: 10px 14px; font-size: 14px; transition: all 0.2s; color: #1e293b; }
    .form-control:focus, .form-select:focus { border-color: #008649; box-shadow: 0 0 0 4px rgba(0,134,73,0.1); }

    /* Buttons */
    .btn-primary { background: linear-gradient(135deg, #008649 0%, #006d3b 100%); border: none; border-radius: 10px; padding: 10px 20px; font-weight: 600; font-size: 14px; }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(0,134,73,0.4); background: linear-gradient(135deg, #006d3b 0%, #005a30 100%); }
    .btn-secondary { background: #f1f5f9; border: 2px solid #e2e8f0; border-radius: 10px; padding: 10px 20px; font-weight: 600; font-size: 14px; color: #64748b; }
    .btn-outline-primary { border: 2px solid #008649; border-radius: 10px; padding: 10px 20px; font-weight: 600; font-size: 14px; color: #008649; background: transparent; }
    .btn-outline-primary:hover { background: #008649; color: #fff; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(0,134,73,0.4); }

    /* Table */
    .table { margin-bottom: 0; }
    .table thead th { background: #f8fafc; border-bottom: 2px solid #e2e8f0; padding: 14px 16px; font-weight: 600; font-size: 13px; color: #475569; text-transform: uppercase; letter-spacing: 0.5px; white-space: nowrap; }
    .table tbody td { padding: 12px 16px; vertical-align: middle; border-bottom: 1px solid #f1f5f9; font-size: 14px; }
    .table tbody tr:hover { background: #f8fafc; }

    /* Loading overlay */
    .loading-overlay { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(255,255,255,0.8); display: flex; align-items: center; justify-content: center; z-index: 100; border-radius: 16px; }
    .spinner-border { width: 3rem; height: 3rem; border-width: 0.3rem; }

    /* Filter section */
    .filter-section { background: #f8fafc; border-radius: 12px; padding: 20px; margin-bottom: 20px; }
    .filter-section-title { font-size: 14px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 2px solid #e2e8f0; }

    /* Grid section */
    .grid-section { margin-top: 24px; }
    .grid-section-title { font-size: 14px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 2px solid #e2e8f0; }

    /* Attendance radios */
    .attendance-radio-group { display: flex; gap: 12px; justify-content: center; }
    .attendance-radio-group label { cursor: pointer; font-weight: 600; font-size: 13px; padding: 4px 10px; border-radius: 6px; border: 2px solid #e2e8f0; transition: all 0.2s; }
    .attendance-radio-group input[type="radio"] { display: none; }
    .attendance-radio-group input[type="radio"][value="P"]:checked + span { background: #dcfce7; color: #16a34a; border-color: #16a34a; }
    .attendance-radio-group input[type="radio"][value="A"]:checked + span { background: #fee2e2; color: #dc2626; border-color: #dc2626; }
    .attendance-radio-group input[type="radio"][value="L"]:checked + span { background: #dbeafe; color: #2563eb; border-color: #2563eb; }
    .radio-label { display: inline-block; padding: 4px 10px; border-radius: 6px; border: 2px solid #e2e8f0; transition: all 0.2s; }

    /* Print spans (hidden on screen) */
    .print-value { display: none; }

    /* Print header (hidden on screen) */
    .print-header { display: none; }

    /* Print CSS */
    @@media print {
        /* Hide everything except the sheet content */
        .no-print, .sidebar, .top-header, .topbar, .top-nav, .navbar,
        .hamburger-btn, .header-actions, .header-search, .header-user-wrapper,
        .toast-container, #toastContainer, .breadcrumb, .page-title,
        .filter-section, .grid-section-title, .loading-overlay { display: none !important; }

        /* Show print header */
        .print-header {
            display: block !important;
            text-align: center;
            margin-bottom: 6px;
            padding: 0;
        }
        .print-header .school-name {
            font-size: 20px;
            font-weight: 700;
            margin: 0;
            padding: 4px 8px 2px 8px;
            line-height: 1.2;
            border-top: 2px solid black;
            border-left: 2px solid black;
            border-right: 2px solid black;
        }
        .print-header .school-address {
            font-size: 12px;
            margin: 0;
            padding: 2px 8px 4px 8px;
            font-weight: 400;
            border-bottom: 2px solid black;
            border-left: 2px solid black;
            border-right: 2px solid black;
        }
        .print-header .sheet-title {
            font-size: 15px;
            font-weight: 700;
            margin: 6px 0 0 0;
            padding: 5px 16px;
            background-color: black !important;
            color: white !important;
            text-align: center;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
        .print-header .date-line {
            text-align: right;
            font-size: 13px;
            font-weight: 500;
            margin: 6px 0;
        }

        /* Reset layout — full width, no margins */
        body { margin: 0 !important; padding: 0 !important; }
        .main-content, .content-area, .container-fluid { margin: 0 !important; padding: 0 !important; width: 100% !important; max-width: 100% !important; }
        .card { box-shadow: none !important; border-radius: 0 !important; border: none !important; margin: 0 !important; }
        .card-body { padding: 0 !important; }
        .grid-section { margin: 0 !important; }

        /* Table styling for print — force black borders on all cells */
        .table-responsive { overflow: visible !important; }
        table, th, td { border: 1px solid black !important; border-collapse: collapse !important; }
        .table {
            font-size: 12px !important;
            width: 100% !important;
            border: 1px solid black !important;
            border-collapse: collapse !important;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
        .table thead th {
            padding: 6px 8px !important;
            font-size: 11px !important;
            font-weight: 700 !important;
            background: none !important;
            border: 1px solid black !important;
            text-transform: none !important;
            letter-spacing: 0 !important;
            color: #000 !important;
        }
        .table tbody td {
            padding: 5px 8px !important;
            border: 1px solid black !important;
            color: #000 !important;
            font-size: 12px !important;
        }
        .table tbody tr:hover { background: none !important; }

        /* Hide screen inputs/radios, show print values */
        .attendance-radio-group { display: none !important; }
        .screen-input { display: none !important; }
        .print-value { display: inline !important; }

        /* Attendance column — leave blank for handwriting */
        .att-cell .print-value { display: none !important; }

        /* Page settings — no browser headers/footers */
            @@page {
                size: portrait;
                margin: 8mm 10mm;
            }
    }
</style>
}

<div class="container-fluid">
    <!-- Print Header (visible only when printing) -->
    <div class="print-header">
        <div class="school-name">SIR SYED MODEL HIGH SCHOOL (Boys&amp;Girls) Hasilpur</div>
        <div class="sheet-title" id="printSheetTitle">Attendance Sheet</div>
    </div>

    <div class="card">
        <div class="card-body position-relative">

            <!-- Loading overlay -->
            <div id="loadingOverlay" class="loading-overlay" style="display: none;">
                <div class="spinner-border text-success" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>

            <!-- Filter Section (hidden on print) -->
            <div class="filter-section no-print">
                <div class="filter-section-title">
                    <i class="bi bi-funnel me-2"></i>Filter
                </div>
                <input type="hidden" id="sessionName" value="0" />
                <div class="row g-3 align-items-end">
                    <div class="col-lg-2 col-md-3 col-sm-6 col-12">
                        <label for="filterClass" class="form-label">Class</label>
                        <select class="form-select" id="filterClass" onchange="loadSections()">
                            <option value="">-- Select Class --</option>
                        </select>
                    </div>
                    <div class="col-lg-2 col-md-3 col-sm-6 col-12">
                        <label for="filterSection" class="form-label">Section</label>
                        <select class="form-select" id="filterSection" disabled>
                            <option value="">-- Select Section --</option>
                        </select>
                    </div>
                    <div class="col-lg-4 col-md-4 col-sm-6 col-12 d-flex align-items-end gap-2">
                        <button type="button" class="btn btn-primary" onclick="loadStudents()">
                            <i class="bi bi-search me-1"></i> Search
                        </button>
                        <button type="button" class="btn btn-secondary" onclick="clearFilters()">
                            <i class="bi bi-x-lg me-1"></i> Clear
                        </button>
                        <button type="button" class="btn btn-outline-primary" onclick="printSheet()">
                            <i class="bi bi-printer me-1"></i> Print
                        </button>
                    </div>
                </div>
            </div>

            <!-- Grid Section -->
            <div class="grid-section">
                <div class="grid-section-title">
                    <i class="bi bi-table me-2"></i>Attendance Sheet
                </div>
                <div class="table-responsive">
                    <table class="table table-hover table-bordered" id="attendanceTable">
                        <thead>
                            <tr>
                                <th style="width: 40px;">Sr.#</th>
                                <th style="width: 60px;">Roll No.</th>
                                <th>Student Name</th>
                                <th>Father's Name</th>
                                <th style="width: 120px;">Contact</th>
                                <th class="text-center" style="width: 70px;"></th>
                                <th style="width: 70px;"></th>
                                <th style="width: 70px;"></th>
                                <th style="width: 70px;"></th>
                                <th style="width: 70px;"></th>
                                <th style="width: 70px;"></th>
                                <th style="width: 150px;"></th>
                            </tr>
                        </thead>
                        <tbody id="attendanceBody">
                            <tr>
                                <td colspan="12" class="text-center text-muted py-4">
                                    Select a Class and Section, then click Search to load students.
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
<script>
    let allStudents = [];

    $(document).ready(function () {
        loadClasses();
    });

    async function loadClasses() {
        try {
            const response = await fetch(`${API_BASE}/class`);
            if (response.ok) {
                const classes = await response.json();
                const select = $('#filterClass');
                classes.forEach(c => {
                    select.append(`<option value="${c.vid}">${c.vName}</option>`);
                });
            }
        } catch (error) {
            toastError('Failed to load classes');
        }
    }

    async function loadSections() {
        const classId = $('#filterClass').val();
        const sectionSelect = $('#filterSection');
        sectionSelect.find('option:not(:first)').remove();
        sectionSelect.prop('disabled', true);

        if (!classId) return;

        try {
            const response = await fetch(`${API_BASE}/section/byClass/${classId}`);
            if (response.ok) {
                const sections = await response.json();
                sections.forEach(s => {
                    sectionSelect.append(`<option value="${s.vid}">${s.vName}</option>`);
                });
                sectionSelect.prop('disabled', false);
            }
        } catch (error) {
            toastError('Failed to load sections');
        }
    }

    async function loadStudents() {
        const classId = $('#filterClass').val();
        const sectionId = $('#filterSection').val();

        if (!classId) {
            toastWarning('Please select a Class');
            return;
        }

        showLoading();
        try {
            const response = await fetch(`${API_BASE}/Student`);
            if (response.ok) {
                const students = await response.json();
                // Client-side filter by class, section, and active status only
                allStudents = students.filter(s => {
                    const matchClass = String(s.classID || s.classId || '') === String(classId);
                    const matchSection = !sectionId || String(s.sectionID || s.sectionId || '') === String(sectionId);
                    const statusID = s.statusID === 1;
                    const isActive = s.isActive === true;

                    return matchClass && matchSection && statusID && isActive;
                });
                // Sort by roll number
                allStudents.sort((a, b) => {
                    const rollA = parseInt(a.rollNo || a.rollNumber) || 0;
                    const rollB = parseInt(b.rollNo || b.rollNumber) || 0;
                    return rollA - rollB;
                });
                renderGrid(allStudents);
                if (allStudents.length === 0) {
                    toastInfo('No students found for selected filters');
                } else {
                    toastSuccess(`${allStudents.length} student(s) loaded`);
                }
            } else {
                toastError('Failed to fetch students');
            }
        } catch (error) {
            toastError('Error: ' + error.message);
        } finally {
            hideLoading();
        }
    }

    function renderGrid(items) {
        const tbody = $('#attendanceBody');
        tbody.empty();

        if (items.length === 0) {
            tbody.html('<tr><td colspan="12" class="text-center text-muted py-4">No students found.</td></tr>');
            return;
        }

        items.forEach((item, index) => {
            const sessionName = item.sessionName || '-';
            const name = item.name || item.nameOfStudent || item.studentName || '-';
            const fathername = item.fatherName || '-';
            const rollNo = item.rollNo || item.rollNumber || '-';
            const contact = item.mobileNo || item.fatherMobile || '-';
            const sr = index + 1;
            const uid = item.id || index;
            
            $('#sessionName').val(sessionName);

            const row = `
                <tr>
                    <td>${sr}</td>
                    <td><strong>${rollNo}</strong></td>
                    <td>${name}</td>
                    <td>${fathername}</td>
                    <td>${contact}</td>
                    <td class="text-center att-cell">
                        <div class="attendance-radio-group">
                            <label>
                                <input type="radio" name="att_${uid}" value="P" checked>
                                <span class="radio-label">P</span>
                            </label>
                            <label>
                                <input type="radio" name="att_${uid}" value="A">
                                <span class="radio-label">A</span>
                            </label>
                            <label>
                                <input type="radio" name="att_${uid}" value="L">
                                <span class="radio-label">L</span>
                            </label>
                        </div>
                        <span class="print-value" id="pv_att_${uid}">P</span>
                    </td>
                    <td>
                        <input type="text" class="form-control form-control-sm screen-input" id="informed_${uid}" placeholder="—">
                        <span class="print-value" id="pv_informed_${uid}"></span>
                    </td>
                    <td>
                        <input type="text" class="form-control form-control-sm screen-input" id="remarks_${uid}" placeholder="—">
                        <span class="print-value" id="pv_remarks_${uid}"></span>
                    </td>
                    <td>
                        <input type="text" class="form-control form-control-sm screen-input" id="remarks_${uid}" placeholder="—">
                        <span class="print-value" id="pv_remarks_${uid}"></span>
                    </td>
                    <td>
                        <input type="text" class="form-control form-control-sm screen-input" id="remarks_${uid}" placeholder="—">
                        <span class="print-value" id="pv_remarks_${uid}"></span>
                    </td>
                    <td>
                        <input type="text" class="form-control form-control-sm screen-input" id="remarks_${uid}" placeholder="—">
                        <span class="print-value" id="pv_remarks_${uid}"></span>
                    </td>
                    <td>
                        <input type="text" class="form-control form-control-sm screen-input" id="remarks_${uid}" placeholder="—">
                        <span class="print-value" id="pv_remarks_${uid}"></span>
                    </td>
                    
                </tr>
            `;
            tbody.append(row);
        });

        // Bind radio change to update print spans
        $('input[type="radio"][name^="att_"]').on('change', function () {
            const name = $(this).attr('name');
            const val = $(this).val();
            $(`#pv_${name}`).text(val);
        });
    }

    function printSheet() {
        if (allStudents.length === 0) {
            toastWarning('No students loaded. Please search first.');
            return;
        }

        // Set class name in title
        const className = $('#filterClass option:selected').text();
        const classDisplay = className !== '-- Select Class --' ? className : '';
        const sectionName = $('#filterSection option:selected').text();
        const sectionDisplay = sectionName !== '-- Select Class --' ? sectionName : '';
        const sessionName = $('#sessionName').val();
                $('#printSheetTitle').html(
            `Attendance Sheet (${classDisplay} - ${sectionDisplay})
            <span style="float:right;">${sessionName}</span>`
        );
        // Copy input values to print spans
        allStudents.forEach((item, index) => {
            const uid = item.id || index;
            const attVal = $(`input[name="att_${uid}"]:checked`).val() || 'P';
            $(`#pv_att_${uid}`).text(attVal);
            $(`#pv_informed_${uid}`).text($(`#informed_${uid}`).val() || '');
            $(`#pv_remarks_${uid}`).text($(`#remarks_${uid}`).val() || '');
        });

        window.print();
    }

    function clearFilters() {
        $('#filterClass').val('').trigger('change');
        $('#filterSection').find('option:not(:first)').remove();
        $('#filterSection').prop('disabled', true);
        allStudents = [];
        $('#attendanceBody').html('<tr><td colspan="8" class="text-center text-muted py-4">Select a Class and Section, then click Search to load students.</td></tr>');
    }

    function showLoading() { $('#loadingOverlay').css('display', 'flex'); }
    function hideLoading() { $('#loadingOverlay').css('display', 'none'); }
</script>
}
