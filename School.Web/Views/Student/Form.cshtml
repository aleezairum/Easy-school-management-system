@section Scripts {
    <script>
        ////const API_BASE = 'http://localhost:5266/api';
        const tabNames = ['Registration Info', 'Student Information', "Father's Information", "Mother's Information", "Guardian's Information", 'Address Information', 'Academic & Fee Info'];
        const tabs = ['registration', 'student', 'father', 'mother', 'guardian', 'address', 'academic'];
        let currentTabIndex = 0;

        $(document).ready(function () {
            // Wizard step click handler
            $('.wizard-step').on('click', function () {
                const stepIndex = parseInt($(this).data('step'));
                goToStep(stepIndex);
            });

            // SMS toggle label updates
            $('#IsSMS').on('change', function () {
                $('#smsLabel').text(this.checked ? 'Enabled' : 'Disabled');
            });
            $('#FatherIsSMS').on('change', function () {
                $('#fatherSmsLabel').text(this.checked ? 'Enabled' : 'Disabled');
            });
            $('#MotherIsSMS').on('change', function () {
                $('#motherSmsLabel').text(this.checked ? 'Enabled' : 'Disabled');
            });
            $('#GuardianIsSMS').on('change', function () {
                $('#guardianSmsLabel').text(this.checked ? 'Enabled' : 'Disabled');
            });

            // Load dropdowns
            loadClassDropdown();
            loadStatusDropdown();
            //loadParentLookups();

            // Cascade section dropdown on class change
            $('#CurrentClass').on('change', function () {
                loadSectionDropdown();
            });

            // Validation and submit handler
            $('#studentForm').on('submit', function (e) {
                var errors = [];
                var firstErrorTab = -1;

                if (!$('#RollNo').val().trim()) { errors.push('Roll No is required'); if (firstErrorTab < 0) firstErrorTab = 0; }
                if (!$('#CurrentClass').val()) { errors.push('Class is required'); if (firstErrorTab < 0) firstErrorTab = 0; }
                if (!$('#Section').val()) { errors.push('Section is required'); if (firstErrorTab < 0) firstErrorTab = 0; }
                if (!$('#Status').val()) { errors.push('Status is required'); if (firstErrorTab < 0) firstErrorTab = 0; }
                if (!$('#NameOfStudent').val().trim()) { errors.push('Student Name (English) is required'); if (firstErrorTab < 0) firstErrorTab = 1; }
                if (!$('#FatherName').val().trim()) { errors.push("Father's Name is required"); if (firstErrorTab < 0) firstErrorTab = 2; }
                if (!$('#FatherCNIC').val().trim()) { errors.push("Father's CNIC is required"); if (firstErrorTab < 0) firstErrorTab = 2; }

                if (errors.length > 0) {
                    e.preventDefault();
                    toastError(errors.join(', '));
                    if (firstErrorTab >= 0) goToStep(firstErrorTab);
                    return false;
                }

                // Re-enable disabled guardian fields so values are submitted
                $('#GuardianName, #GuardianNameUrdu, #GuardianCNIC, #GuardianRelation, #GuardianMobile, #GuardianIsSMS').prop('disabled', false);
            });

            // Initialize
            updateWizard();

            // Apply guardian type state on page load (for edit mode)
            var initialGuardianType = parseInt($('#GuardianType').val()) || 2;
            if (initialGuardianType === 0 || initialGuardianType === 1) {
                $('#GuardianName, #GuardianNameUrdu, #GuardianCNIC, #GuardianRelation, #GuardianMobile, #GuardianIsSMS').prop('disabled', true);
            }
        });

        // Load class dropdown
        async function loadClassDropdown() {
            try {
                const response = await fetch(`${API_BASE}/class`);
                if (response.ok) {
                    const classes = await response.json();
                    const select = $('#CurrentClass');
                    classes.forEach(c => {
                        if (c.isActive) {
                            select.append(`<option value="${c.vName}" data-id="${c.vid}">${c.vName}</option>`);
                        }
                    });
                    // Set selected class from model
                    if (selectedClass) {
                        select.val(selectedClass);
                    }
                     await loadSectionDropdown();
                }
            } catch (error) {
                console.error('Error loading classes:', error);
            }
        }

        // Load student status dropdown
        async function loadStatusDropdown() {
            try {
                const response = await fetch(`${API_BASE}/studentstatus`);
                if (response.ok) {
                    const statuses = await response.json();
                    const select = $('#Status');

                    select.empty(); // clear old options

                    statuses.forEach(s => {
                        if (s.isActive) {
                            select.append(`<option value="${s.vName}" data-id="${s.vid}">${s.vName}</option>`);
                        }
                    });
                    // Match by StatusID first (reliable), then fall back to name
                    if (selectedStatusId) {
                        select.find('option').each(function() {
                            if ($(this).attr('data-id') === selectedStatusId) {
                                select.val($(this).val());
                                return false;
                            }
                        });
                    } else if (selectedStatus) {
                        select.val(selectedStatus);
                    }
                }
            } catch (error) {
                console.error('Error loading statuses:', error);
            }
        }
        // Load section dropdown based on selected class
        async function loadSectionDropdown() {
            const select = $('#Section');
            select.find('option:not(:first)').remove();

            const classId = $('#CurrentClass').find(':selected').attr('data-id');
            if (!classId || classId === 'undefined') return;

            try { const response = await fetch(`${API_BASE}/section/byClass/${classId}`);
                if (response.ok) {
                    const data = await response.json();
                    const sections = Array.isArray(data) ? data : data.data ?? data.items ?? data.sections ?? [];

                    sections.forEach(s => {
                        if (s.isActive) {
                            select.append(`<option value="${s.vName}" data-id="${s.vid}">${s.vName}</option>`);
                        }
                    });
                    // Set selected section from model
            if (selectedSection) {
                select.val(selectedSection);
            }
                } else {
                    console.error('Failed to load sections, status:', response.status);
                }
            } catch (error) {
                console.error('Error loading sections:', error);
            }
        }

        // Load parent CNIC lookup dropdowns
        async function loadParentLookups() {
            try {
                const response = await fetch(`${API_BASE}/student/parent-lookups`);
                if (!response.ok) return;
                const data = await response.json();

                const fatherSelect = $('#fatherCnicLookup');
                const motherSelect = $('#motherCnicLookup');

                const fatherSeen = new Set();
                const motherSeen = new Set();

                data.forEach(s => {
                    if (s.fatherCNIC && !fatherSeen.has(s.fatherCNIC)) {
                        fatherSeen.add(s.fatherCNIC);
                        fatherSelect.append(`<option value="${s.fatherCNIC}">${s.fatherCNIC} - ${s.fatherName || ''} (${s.nameOfStudent || ''})</option>`);
                    }
                    if (s.motherCNIC && !motherSeen.has(s.motherCNIC)) {
                        motherSeen.add(s.motherCNIC);
                        motherSelect.append(`<option value="${s.motherCNIC}">${s.motherCNIC} - ${s.motherName || ''} (${s.nameOfStudent || ''})</option>`);
                    }
                });
            } catch (error) {
                console.error('Error loading parent lookups:', error);
            }
        }

        // Load parent data by CNIC from lookup dropdown
        async function loadParentByCNIC(cnic, type) {
            if (!cnic) return;

            const endpoint = type === 'mother' ? 'by-mother-cnic' : type === 'guardian' ? 'by-guardian-cnic' : 'by-father-cnic';

            $('#loadingOverlay').show();
            try {
                const response = await fetch(`${API_BASE}/student/${endpoint}/${encodeURIComponent(cnic)}`);
                if (response.ok) {
                    const data = await response.json();

                    $('#FatherName').val(data.fatherName || '');
                    $('#FatherNameUrdu').val(data.fatherNameUrdu || '');
                    $('#FatherCNIC').val(data.fatherCNIC || '');
                    $('#FatherOccupation').val(data.fatherOccupation || '');
                    $('#FatherMobile').val(data.fatherMobile || '');
                    $('#FatherIsSMS').prop('checked', data.fatherIsSMS || false);
                    $('#fatherSmsLabel').text(data.fatherIsSMS ? 'Enabled' : 'Disabled');

                    $('#MotherName').val(data.motherName || '');
                    $('#MotherNameUrdu').val(data.motherNameUrdu || '');
                    $('#MotherCNIC').val(data.motherCNIC || '');
                    $('#MotherMobile').val(data.motherMobile || '');
                    $('#MotherIsSMS').prop('checked', data.motherIsSMS || false);
                    $('#motherSmsLabel').text(data.motherIsSMS ? 'Enabled' : 'Disabled');

                    $('#GuardianName').val(data.guardianName || '');
                    $('#GuardianNameUrdu').val(data.guardianNameUrdu || '');
                    $('#GuardianCNIC').val(data.guardianCNIC || '');
                    $('#GuardianRelation').val(data.guardianRelation || '');
                    $('#GuardianMobile').val(data.guardianMobile || '');
                    $('#GuardianIsSMS').prop('checked', data.guardianIsSMS || false);
                    $('#guardianSmsLabel').text(data.guardianIsSMS ? 'Enabled' : 'Disabled');

                    $('#guardianOther').prop('checked', true);
                    $('#GuardianType').val(2);
                    $('#GuardianName, #GuardianNameUrdu, #GuardianCNIC, #GuardianRelation, #GuardianMobile, #GuardianIsSMS').prop('disabled', false);

                    showAlert('Parent data found and auto-filled successfully!', 'success');
                } else {
                    showAlert('No record found against this CNIC', 'warning');
                }
            } catch (error) {
                console.error('Error loading parent data:', error);
                showAlert('Error loading parent data: ' + error.message, 'danger');
            } finally {
                $('#loadingOverlay').hide();
            }
        }

        // Auto-calculate percentage from marks
        function calculatePercentage() {
            var total = parseFloat($('#TotalMarks').val());
            var obtained = parseFloat($('#MarksObtained').val());
            if (total > 0 && obtained >= 0) {
                $('#Percentage').val(((obtained / total) * 100).toFixed(2));
            } else {
                $('#Percentage').val('');
            }
        }

        // Guardian type change handler (0=Father, 1=Mother, 2=Other)
        function onGuardianTypeChange(type) {
            $('#GuardianType').val(type);
            const guardianFields = ['#GuardianName', '#GuardianNameUrdu', '#GuardianCNIC', '#GuardianRelation', '#GuardianMobile', '#GuardianIsSMS'];

            if (type === 0) {
                $('#GuardianName').val($('#FatherName').val());
                $('#GuardianNameUrdu').val($('#FatherNameUrdu').val());
                $('#GuardianCNIC').val($('#FatherCNIC').val());
                $('#GuardianRelation').val('Father');
                $('#GuardianMobile').val($('#FatherMobile').val());
                $('#GuardianIsSMS').prop('checked', $('#FatherIsSMS').is(':checked'));
                $('#guardianSmsLabel').text($('#FatherIsSMS').is(':checked') ? 'Enabled' : 'Disabled');
                guardianFields.forEach(f => $(f).prop('disabled', true));
            } else if (type === 1) {
                $('#GuardianName').val($('#MotherName').val());
                $('#GuardianNameUrdu').val($('#MotherNameUrdu').val());
                $('#GuardianCNIC').val($('#MotherCNIC').val());
                $('#GuardianRelation').val('Mother');
                $('#GuardianMobile').val($('#MotherMobile').val());
                $('#GuardianIsSMS').prop('checked', $('#MotherIsSMS').is(':checked'));
                $('#guardianSmsLabel').text($('#MotherIsSMS').is(':checked') ? 'Enabled' : 'Disabled');
                guardianFields.forEach(f => $(f).prop('disabled', true));
            } else {
                $('#GuardianName').val('');
                $('#GuardianNameUrdu').val('');
                $('#GuardianCNIC').val('');
                $('#GuardianRelation').val('');
                $('#GuardianMobile').val('');
                $('#GuardianIsSMS').prop('checked', false);
                $('#guardianSmsLabel').text('Disabled');
                guardianFields.forEach(f => $(f).prop('disabled', false));
            }
        }

        // Load admission data and populate form
        function loadAdmissionData(admissionId) {
            if (!admissionId) {
                // Clear the AdmissionId hidden field
                $('#AdmissionId').val('');
                return;
            }

            // Show loading
            $('#loadingOverlay').show();

            // Fetch admission details from API
            $.ajax({
                url: `${API_BASE}/Admission/${admissionId}`,
                method: 'GET',
                success: function(data) {
                    // Set AdmissionId
                    $('#AdmissionId').val(admissionId);

                    // Populate Registration Info
                    $('#AdmissionNo').val(data.admissionNo || '');
                    $('#DateOfAdmission').val(data.dateOfAdmission ? data.dateOfAdmission.split('T')[0] : '');
                    $('#CurrentClass').val(data.classSought || '').trigger('change');

                    // Populate Student Info
                    $('#NameOfStudent').val(data.nameOfStudent || '');
                    $('#NameOfStudentUrdu').val(data.nameOfStudentUrdu || '');
                    $('#MobileNo').val(data.mobileNo || '');
                    $('#IsSMS').prop('checked', data.isSMS || false);
                    $('#smsLabel').text(data.isSMS ? 'Enabled' : 'Disabled');
                    $('#DateOfBirth').val(data.dateOfBirth ? data.dateOfBirth.split('T')[0] : '');
                    $('#DateOfBirthInWords').val(data.dateOfBirthInWords || '');
                    $('#PlaceOfBirth').val(data.placeOfBirth || '');
                    $('#FormBNo').val(data.formBNo || '');
                    $('#Gender').val(data.gender || '');
                    $('#Religion').val(data.religion || '');

                    // Populate Father Info
                    $('#FatherName').val(data.fatherName || '');
                    $('#FatherNameUrdu').val(data.fatherNameUrdu || '');
                    $('#FatherCNIC').val(data.fatherCNIC || '');
                    $('#FatherOccupation').val(data.fatherOccupation || '');
                    $('#FatherMobile').val(data.fatherMobile || '');
                    $('#FatherIsSMS').prop('checked', data.fatherIsSMS || false);
                    $('#fatherSmsLabel').text(data.fatherIsSMS ? 'Enabled' : 'Disabled');

                    // Populate Mother Info
                    $('#MotherName').val(data.motherName || '');
                    $('#MotherNameUrdu').val(data.motherNameUrdu || '');
                    $('#MotherCNIC').val(data.motherCNIC || '');
                    $('#MotherMobile').val(data.motherMobile || '');
                    $('#MotherIsSMS').prop('checked', data.motherIsSMS || false);
                    $('#motherSmsLabel').text(data.motherIsSMS ? 'Enabled' : 'Disabled');

                    // Populate Guardian Info
                    var gType = data.guardianType != null ? data.guardianType : 2;
                    $('#GuardianType').val(gType);
                    $('input[name="guardianTypeRadio"][value="' + gType + '"]').prop('checked', true);
                    $('#GuardianName').val(data.guardianName || '');
                    $('#GuardianNameUrdu').val(data.guardianNameUrdu || '');
                    $('#GuardianCNIC').val(data.guardianCNIC || '');
                    $('#GuardianRelation').val(data.guardianRelation || '');
                    $('#GuardianMobile').val(data.guardianMobile || '');
                    $('#GuardianIsSMS').prop('checked', data.guardianIsSMS || false);
                    $('#guardianSmsLabel').text(data.guardianIsSMS ? 'Enabled' : 'Disabled');
                    if (gType === 0 || gType === 1) {
                        $('#GuardianName, #GuardianNameUrdu, #GuardianCNIC, #GuardianRelation, #GuardianMobile, #GuardianIsSMS').prop('disabled', true);
                    } else {
                        $('#GuardianName, #GuardianNameUrdu, #GuardianCNIC, #GuardianRelation, #GuardianMobile, #GuardianIsSMS').prop('disabled', false);
                    }

                    // Populate Address Info
                    $('#PresentAddress').val(data.presentAddress || '');
                    $('#PresentAddressUrdu').val(data.presentAddressUrdu || '');
                    $('#PermanentAddress').val(data.permanentAddress || '');
                    $('#PermanentAddressUrdu').val(data.permanentAddressUrdu || '');
                    $('#PhoneResidence').val(data.phoneResidence || '');
                    $('#EmergencyContact').val(data.emergencyContact || '');

                    // Populate Academic Info
                    $('#PreviousSchool').val(data.previousSchool || '');
                    $('#LastClass').val(data.lastClass || '');
                    $('#Board').val(data.board || '');
                    $('#YearOfPassing').val(data.yearOfPassing || '');
                    $('#MarksObtained').val(data.marksObtained || '');
                    $('#TotalMarks').val(data.totalMarks || '');
                    $('#Percentage').val(data.percentage || '');

                    // Populate Fee Info
                    $('#AdmissionFee').val(data.admissionFee || '');

                    // Handle photo if exists
                    if (data.studentPhoto) {
                        $('#photoPreview').attr('src', data.studentPhoto).show();
                        $('#photoPlaceholder').hide();
                        $('#removePhoto').show();
                        $('#StudentPhoto').val(data.studentPhoto);
                    }

                    showAlert('Admission data loaded successfully! Please review and add any additional details.', 'success');
                    $('#loadingOverlay').hide();
                },
                error: function(xhr, status, error) {
                    showAlert('Failed to load admission data. Please try again or enter details manually.', 'danger');
                    $('#loadingOverlay').hide();
                }
            });
        }

        // Go to specific step
        function goToStep(stepIndex) {
            if (stepIndex < 0 || stepIndex >= tabs.length) return;

            // Hide all tab panes
            $('.tab-pane').removeClass('show active');

            // Show target pane
            $('#' + tabs[stepIndex]).addClass('show active');

            // Update current index
            currentTabIndex = stepIndex;

            // Update wizard UI
            updateWizard();
        }

        // Update wizard UI
        function updateWizard() {
            const $steps = $('.wizard-step');

            $steps.each(function (index) {
                $(this).removeClass('active completed');

                if (index < currentTabIndex) {
                    $(this).addClass('completed');
                } else if (index === currentTabIndex) {
                    $(this).addClass('active');
                }
            });

            // Update progress line
            const progressWidth = currentTabIndex > 0 ? ((currentTabIndex) / (tabs.length - 1)) * 100 : 0;
            $('#wizardProgressLine').css('width', progressWidth + '%');

            // Update progress bar and text
            const progress = ((currentTabIndex + 1) / tabs.length) * 100;
            $('#formProgress').css('width', progress + '%');
            $('#currentStep').text(currentTabIndex + 1);
            $('#stepName').text(tabNames[currentTabIndex]);
        }

        // Navigate to next tab
        function nextTab() {
            if (currentTabIndex < tabs.length - 1) {
                goToStep(currentTabIndex + 1);
            }
        }

        // Navigate to previous tab
        function prevTab() {
            if (currentTabIndex > 0) {
                goToStep(currentTabIndex - 1);
            }
        }

        // Reset form
        function resetForm() {
            if (confirm('Are you sure you want to clear all fields?')) {
                document.getElementById('studentForm').reset();
                // Go back to first tab
                goToStep(0);
            }
        }

        // Show alert
        function showAlert(message, type) {
            if (type === 'success') {
                toastSuccess(message);
            } else if (type === 'danger' || type === 'error') {
                toastError(message);
            } else if (type === 'warning') {
                toastWarning(message);
            } else {
                toastInfo(message);
            }
        }

        // Photo upload preview
        $('#PhotoFile').on('change', function (e) {
            const file = e.target.files[0];
            if (file) {
                // Validate file type
                const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png'];
                if (!allowedTypes.includes(file.type)) {
                    showAlert('Please select a valid image file (JPG, JPEG, or PNG).', 'danger');
                    this.value = '';
                    return;
                }

                // Validate file size (2MB max)
                const maxSize = 2 * 1024 * 1024; // 2MB in bytes
                if (file.size > maxSize) {
                    showAlert('File size must be less than 2MB.', 'danger');
                    this.value = '';
                    return;
                }

                // Show preview
                const reader = new FileReader();
                reader.onload = function (event) {
                    $('#photoPreview').attr('src', event.target.result).show();
                    $('#photoPlaceholder').hide();
                    $('#removePhoto').show();
                };
                reader.readAsDataURL(file);
            }
        });

        // Remove photo
        $('#removePhoto').on('click', function () {
            $('#PhotoFile').val('');
            $('#photoPreview').attr('src', '').hide();
            $('#photoPlaceholder').show();
            $('#removePhoto').hide();
            $('#StudentPhoto').val('');
        });


        async function submitStudentForm() {
            // --- Required field validation ---
            const requiredFields = [
                { id: 'RollNo',         label: 'Roll No.' },
                { id: 'CurrentClass',   label: 'Current Class' },
                { id: 'Section',        label: 'Section' },
                { id: 'Status',         label: 'Status' },
                { id: 'NameOfStudent',  label: 'Name of Student' },
                { id: 'FatherName',     label: "Father's Name" },
                { id: 'FatherCNIC',     label: "Father's CNIC" }
            ];

            for (const field of requiredFields) {
                const el = document.getElementById(field.id);
                if (!el || !el.value.trim()) {
                    alert(`Please fill in the required field: ${field.label}`);
                    el?.focus();
                    return;
                }
            }

            // --- Helper: get element value safely ---
            const val  = (id) => document.getElementById(id)?.value?.trim() || null;
            const intVal  = (id) => { const v = val(id); return v ? parseInt(v) : null; };
            const boolVal = (id) => document.getElementById(id)?.checked ?? false;
            const dateVal = (id) => { const v = val(id); return v ? v : null; }; // "yyyy-MM-dd" — API handles parsing

            // --- Build DTO matching StudentSaveDto ---
            const dto = {
                // Identity
                VID:              intVal('Id') || 0,
                ParentID:         intVal('AdmissionId') || 0,

                // Registration Info (Tab 1)
                RegistrationNo:   val('RegistrationNo')|| '',
                AdmissionNo:      val('AdmissionNo')|| '',
                AdmissionDate:    dateVal('DateOfAdmission'),
                RollNo:           val('RollNo')|| '',
                ClassRollNo:      val('RollNo')|| '',           // same roll used as class roll
                ClassID:          parseInt($('#CurrentClass').find(':selected').attr('data-id')) || 0,
                ClassName:        $('#CurrentClass').find(':selected').text() || '',
                SectionID:        parseInt($('#Section').find(':selected').attr('data-id')) || 0,
                SectionName:      $('#Section').find(':selected').text() || '',
                StatusID:         parseInt($('#Status').find(':selected').attr('data-id')) || 0,
                SessionID:        1,   // set if you have a session dropdown, otherwise default
                SessionName:        '',

                // Student Info (Tab 2)
                Name:             val('NameOfStudent')|| '',
                Name_Urdu:        val('NameOfStudentUrdu')|| '',
                MobileNo:         val('MobileNo')|| '',
                IsSMS:            boolVal('IsSMS')|| false,
                DOB:              dateVal('DateOfBirth'),
                BirthPlace:       val('PlaceOfBirth')|| '',
                FormBNo:          val('FormBNo')|| '',
                Gender:           val('Gender') || '',
                Religion:         val('Religion')|| '',
                Caste:            '',                    // no field in form; extend if needed

                // Father Info (Tab 3)
                FatherName:       val('FatherName')|| '',
                FatherNameUrdu:   val('FatherNameUrdu')|| '',
                FatherCNIC:       val('FatherCNIC')|| '',
                FatherMobile:     val('FatherMobile')|| '',
                IsFatherSMS:      boolVal('FatherIsSMS')|| false,
                Occupation:       val('FatherOccupation')|| '',

                // Mother Info (Tab 4)
                MotherName:       val('MotherName')|| '',
                MotherNameUrdu:   val('MotherNameUrdu')|| '',
                MotherCNIC:       val('MotherCNIC')|| '',
                MotherMobile:     val('MotherMobile')|| '',
                IsMotherSMS:      boolVal('MotherIsSMS')|| false,

                // Guardian Info (Tab 5)
                GuardianType:     intVal('GuardianType') || 0,
                GuardianName:     val('GuardianName')|| '',
                GuardianNameUrdu: val('GuardianNameUrdu')|| '',
                GuardianCNIC:     val('GuardianCNIC')|| '',
                GuardianMobile:   val('GuardianMobile')|| '',
                IsGuardianSMS:    boolVal('GuardianIsSMS')|| false,
                GuardianRelation: val('GuardianRelation')|| '',

                // Address (Tab 6)
                Address:          val('PresentAddress')|| '',   // PresentAddress → Address

                // Academic (Tab 7) — no direct DTO fields; extend DTO if needed
                // Fee, GradeID, GradeName — set if you have those dropdowns
                Fee:              0,
                GradeID:          null,
                GradeName:        '',
                IsAvailAcademy:   false,

                // Audit
                IsActive:         true,
                InsertedBy:       null,   // filled server-side from JWT
                InsertedDate:     null,
                InsertedIp:       null,
                UpdatedBy:        null,
                UpdatedDate:      null,
                UpdatedIp:        null
            };

            console.log('Submitting DTO:', dto); // remove in production

            // --- Determine POST vs PUT ---
            const isEdit = dto.VID > 0;
            const method = isEdit ? 'PUT' : 'POST';
            const url    = isEdit
                ? `${API_BASE}/Student/${dto.VID}`
                : `${API_BASE}/Student`;

            // --- Loading state ---
            const submitBtn = document.querySelector('[onclick="submitStudentForm()"]');
            const originalHTML = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Saving...';

            try {
                const response = await fetch(url, {
                    method:  method,
                    headers: { 'Content-Type': 'application/json' },
                    body:    JSON.stringify(dto)
                });

                if (!response.ok) {
                    let errorMessage = `Server error: ${response.status} ${response.statusText}`;
                    try {
                        const errorData = await response.json();
                        // ASP.NET validation errors come back as errorData.errors object
                        if (errorData.errors) {
                            errorMessage = Object.entries(errorData.errors)
                                .map(([field, msgs]) => `${field}: ${msgs.join(', ')}`)
                                .join('\n');
                        } else {
                            errorMessage = errorData.message || errorData.title || JSON.stringify(errorData);
                        }
                    } catch { /* non-JSON error body */ }
                    throw new Error(errorMessage);
                }

                const result = await response.json();
                toastSuccess(isEdit ? 'Student updated successfully!' : 'Student saved successfully!');

                // Redirect to student list after short delay
                setTimeout(() => { window.location.href = '/Student'; }, 1500);

            } catch (error) {
                console.error('API Error:', error);
                toastError(`Failed to save student: ${error.message}`);
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalHTML;
            }
        }

        // Keyboard navigation
        $(document).keydown(function (e) {
            // Alt + Right Arrow = Next Tab
            if (e.altKey && e.keyCode === 39) {
                e.preventDefault();
                nextTab();
            }
            // Alt + Left Arrow = Previous Tab
            if (e.altKey && e.keyCode === 37) {
                e.preventDefault();
                prevTab();
            }
        });
    </script>
}
