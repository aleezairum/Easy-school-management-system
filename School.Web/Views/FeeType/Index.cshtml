@{
    ViewData["Title"] = "Fee Type";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    .card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
        margin-bottom: 24px;
    }

    .card-body {
        padding: 24px;
    }

    .form-label {
        font-weight: 500;
        color: #475569;
        margin-bottom: 8px;
        font-size: 14px;
    }

    .form-control {
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 14px;
        transition: all 0.2s;
    }

    .form-control:focus {
        border-color: #008649;
        box-shadow: 0 0 0 4px rgba(0, 134, 73, 0.1);
    }

    .form-check-input {
        width: 18px;
        height: 18px;
        border: 2px solid #cbd5e1;
        border-radius: 4px;
        cursor: pointer;
    }

    .form-check-input:checked {
        background-color: #008649;
        border-color: #008649;
    }

    .form-check-input:focus {
        box-shadow: 0 0 0 4px rgba(0, 134, 73, 0.1);
    }

    .btn-info {
        background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
        border: none;
        border-radius: 8px;
        padding: 6px 12px;
        font-weight: 600;
        font-size: 13px;
        color: white;
        transition: all 0.2s;
    }

    .btn-info:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(14, 165, 233, 0.4);
        color: white;
    }

    .btn-danger {
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        border: none;
        border-radius: 8px;
        padding: 6px 12px;
        font-weight: 600;
        font-size: 13px;
        color: white;
        transition: all 0.2s;
    }

    .btn-danger:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.4);
        color: white;
    }

    .table {
        margin-bottom: 0;
    }

    .table thead th {
        background: #f8fafc;
        border-bottom: 2px solid #e2e8f0;
        padding: 14px 16px;
        font-weight: 600;
        font-size: 13px;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        white-space: nowrap;
    }

    .table tbody td {
        padding: 12px 16px;
        vertical-align: middle;
        border-bottom: 1px solid #f1f5f9;
        font-size: 14px;
    }

    .table tbody tr:hover {
        background: #f8fafc;
    }

    .table tbody tr.selected {
        background: #ecfdf5;
        border-left: 3px solid #008649;
    }

    .loading-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255, 255, 255, 0.8);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 100;
        border-radius: 16px;
    }

    .spinner-border {
        width: 3rem;
        height: 3rem;
        border-width: 0.3rem;
    }

    .form-section {
        background: #f8fafc;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 20px;
    }

    .form-section-title {
        font-size: 14px;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 16px;
        padding-bottom: 8px;
        border-bottom: 2px solid #e2e8f0;
    }

    .grid-section {
        margin-top: 24px;
    }

    .grid-section-title {
        font-size: 14px;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 16px;
        padding-bottom: 8px;
        border-bottom: 2px solid #e2e8f0;
    }

    /* Save Button */
    .btn-save {
        background-color: #00A651;
        color: white;
        font-weight: 600;
        font-size: 14px;
        padding: 12px 24px;
        border: none;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-save:hover {
        background-color: #008F45;
    }

    .btn-save:active {
        background-color: #007A3A;
        box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.15);
    }

    /* Clear Button */
    .btn-clear {
        background-color: transparent;
        color: #6B7280;
        font-weight: 600;
        font-size: 14px;
        padding: 12px 24px;
        border: 2px solid #D1D5DB;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-clear:hover {
        background-color: #F3F4F6;
        border-color: #9CA3AF;
    }

    .btn-clear:active {
        background-color: #E5E7EB;
    }
</style>

<div class="container-fluid">
    <div id="alertContainer"></div>

    <div class="card">
        <div class="card-body position-relative">
            <div id="loadingOverlay" class="loading-overlay" style="display: none;">
                <div class="spinner-border text-success" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>

            <!-- Form Section -->
            <div class="form-section">
                <div class="form-section-title">
                    <i class="bi bi-pencil-square me-2"></i><span id="formTitle">Add New Fee Type</span>
                </div>
                <form id="feeTypeForm">
                    <input type="hidden" id="feeTypeId" value="0" />

                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            <label for="feeTypeName" class="form-label">Fee Type <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="feeTypeName" placeholder="e.g., Tuition Fee, Exam Fee" required />
                        </div>
                        <div class="col-md-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="isActive" checked />
                                <label class="form-check-label" for="isActive">Active</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="d-flex gap-2">
                                <button type="button" class="btn-save" onclick="saveFeeType()">
                                    <i class="bi bi-check-lg"></i> Save
                                </button>
                                <button type="button" class="btn-clear" onclick="resetForm()">
                                    <i class="bi bi-x-lg"></i> Clear
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Grid Section -->
            <div class="grid-section">
                <div class="grid-section-title">
                    <i class="bi bi-table me-2"></i>Fee Types List
                </div>
                <div class="table-responsive">
                    <table class="table table-hover" id="feeTypesTable">
                        <thead>
                            <tr>
                                <th style="width: 60px;">SR#</th>
                                <th>Fee Type</th>
                                <th class="text-center" style="width: 100px;">Status</th>
                                <th class="text-center" style="width: 150px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="feeTypesBody">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let editingFeeTypeId = 0;

        $(document).ready(function () {
            loadFeeTypes();
        });

        async function loadFeeTypes() {
            showLoading();
            try {
                const response = await fetch(`${API_BASE}/feetype`);
                if (response.ok) {
                    const data = await response.json();
                    renderFeeTypesList(data);
                } else {
                    showAlert('Failed to load fee types', 'danger');
                }
            } catch (error) {
                console.error('Error loading fee types:', error);
                showAlert('Error loading fee types: ' + error.message, 'danger');
            } finally {
                hideLoading();
            }
        }

        function renderFeeTypesList(items) {
            const tbody = $('#feeTypesBody');
            tbody.empty();

            if (items.length === 0) {
                tbody.html('<tr><td colspan="4" class="text-center text-muted py-4">No fee types found. Add a new fee type using the form above.</td></tr>');
                return;
            }

            items.forEach((item, index) => {
                const row = `
                    <tr data-id="${item.vid}" class="${editingFeeTypeId === item.vid ? 'selected' : ''}">
                        <td>${index + 1}</td>
                        <td><strong>${item.vName}</strong></td>
                        <td class="text-center">
                            <span class="badge ${item.isActive ? 'bg-success' : 'bg-secondary'}">
                                ${item.isActive ? 'Active' : 'Inactive'}
                            </span>
                        </td>
                        <td class="text-center">
                            <button type="button" class="btn btn-sm btn-info me-1" onclick="editFeeType(${item.vid})" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-danger" onclick="deleteFeeType(${item.vid}, '${item.vName}')" title="Delete">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                `;
                tbody.append(row);
            });
        }

        async function editFeeType(id) {
            showLoading();
            try {
                const response = await fetch(`${API_BASE}/feetype/${id}`);
                if (response.ok) {
                    const data = await response.json();
                    populateForm(data);
                    editingFeeTypeId = id;
                    $('#formTitle').text('Edit Fee Type');

                    $('#feeTypesBody tr').removeClass('selected');
                    $(`#feeTypesBody tr[data-id="${id}"]`).addClass('selected');

                    $('html, body').animate({
                        scrollTop: $('.form-section').offset().top - 100
                    }, 300);
                } else {
                    showAlert('Failed to load fee type', 'danger');
                }
            } catch (error) {
                console.error('Error loading fee type:', error);
                showAlert('Error loading fee type: ' + error.message, 'danger');
            } finally {
                hideLoading();
            }
        }

        async function deleteFeeType(id, name) {
            if (!confirm(`Are you sure you want to delete the fee type "${name}"?`)) {
                return;
            }

            showLoading();
            try {
                const response = await fetch(`${API_BASE}/feetype/${id}`, {
                    method: 'DELETE'
                });

                if (response.ok) {
                    showAlert('Fee type deleted successfully!', 'success');
                    if (editingFeeTypeId === id) {
                        resetForm();
                    }
                    await loadFeeTypes();
                } else {
                    const error = await response.json();
                    showAlert(error.message || 'Failed to delete fee type', 'danger');
                }
            } catch (error) {
                console.error('Error deleting fee type:', error);
                showAlert('Error deleting fee type: ' + error.message, 'danger');
            } finally {
                hideLoading();
            }
        }

        function populateForm(data) {
            $('#feeTypeId').val(data.vid);
            $('#feeTypeName').val(data.vName);
            $('#isActive').prop('checked', data.isActive);
        }

        function resetForm() {
            $('#feeTypeId').val('0');
            $('#feeTypeName').val('');
            $('#isActive').prop('checked', true);
            $('#formTitle').text('Add New Fee Type');
            editingFeeTypeId = 0;
            $('#feeTypesBody tr').removeClass('selected');
        }

        async function saveFeeType() {
            const name = $('#feeTypeName').val().trim();

            if (!name) {
                showAlert('Please enter a fee type name', 'danger');
                $('#feeTypeName').focus();
                return;
            }

            const id = parseInt($('#feeTypeId').val()) || 0;
            const data = {
                VID: id,
                VName: name,
                IsActive: $('#isActive').is(':checked')
            };

            showLoading();
            try {
                const response = await fetch(`${API_BASE}/feetype`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                if (response.ok) {
                    showAlert(id === 0 ? 'Fee type created successfully!' : 'Fee type updated successfully!', 'success');
                    resetForm();
                    await loadFeeTypes();
                } else {
                    const error = await response.json();
                    showAlert(error.message || 'Failed to save fee type', 'danger');
                }
            } catch (error) {
                console.error('Error saving fee type:', error);
                showAlert('Error saving fee type: ' + error.message, 'danger');
            } finally {
                hideLoading();
            }
        }

        function showLoading() {
            $('#loadingOverlay').show();
        }

        function hideLoading() {
            $('#loadingOverlay').hide();
        }

        function showAlert(message, type) {
            if (type === 'success') {
                toastSuccess(message);
            } else if (type === 'danger' || type === 'error') {
                toastError(message);
            } else if (type === 'warning') {
                toastWarning(message);
            } else {
                toastInfo(message);
            }
        }
    </script>
}
