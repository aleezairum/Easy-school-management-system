@{
    ViewData["Title"] = "Fee Vouchers";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <style>
        .flatpickr-day.selected,
        .flatpickr-day.startRange,
        .flatpickr-day.endRange,
        .flatpickr-day.selected.inRange {
            background: #008649 !important;
            border-color: #008649 !important;
        }

        .flatpickr-day.inRange {
            background: rgba(0,134,73,0.15) !important;
            box-shadow: -5px 0 0 rgba(0,134,73,0.15), 5px 0 0 rgba(0,134,73,0.15) !important;
        }

        .main-card {
            border: none;
            border-radius: 16px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.08);
            overflow: hidden;
        }

        .top-bar {
            background: linear-gradient(135deg, #008649 0%, #005f33 100%);
            color: white;
        }

        .page-icon {
            width: 44px;
            height: 44px;
            background: rgba(255,255,255,0.2);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .page-title {
            font-size: 16px;
            font-weight: 700;
            letter-spacing: 0.3px;
        }

        .page-subtitle {
            font-size: 12px;
            opacity: 0.8;
            margin-top: 2px;
        }

        .btn-add {
            background: rgba(255,255,255,0.15);
            color: white;
            border: 1px solid rgba(255,255,255,0.3);
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            padding: 8px 16px;
        }

        .btn-add:hover {
            background: rgba(255,255,255,0.25);
            color: white;
        }

        .section-card {
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            overflow: hidden;
            margin-top: 16px;
        }

        .section-header {
            background: #f8fafc;
            padding: 10px 16px;
            font-size: 13px;
            font-weight: 600;
            color: #475569;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        .section-body {
            padding: 16px;
        }

        .form-label {
            font-size: 12px;
            font-weight: 600;
            color: #64748b;
            margin-bottom: 5px;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .form-control, .form-select {
            border: 1.5px solid #e2e8f0;
            border-radius: 8px;
            font-size: 13px;
            padding: 8px 12px;
            transition: all 0.2s;
        }

        .form-control:focus, .form-select:focus {
            border-color: #008649;
            box-shadow: 0 0 0 3px rgba(0,134,73,0.1);
        }

        .voucher-table thead th {
            background: #f8fafc;
            font-size: 12px;
            font-weight: 600;
            color: #64748b;
            padding: 10px 12px;
            border-bottom: 2px solid #e2e8f0;
            white-space: nowrap;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .voucher-table tbody td {
            font-size: 13px;
            padding: 10px 12px;
            vertical-align: middle;
            border-bottom: 1px solid #f1f5f9;
        }

        .voucher-table tbody tr:hover {
            background: #f0fdf4;
        }

        .btn-action {
            border: none;
            border-radius: 6px;
            padding: 5px 10px;
            font-size: 12px;
            font-weight: 600;
            color: white;
            transition: all 0.15s;
        }

        .btn-action:hover {
            transform: translateY(-1px);
            color: white;
        }

        .btn-edit {
            background: linear-gradient(135deg, #008649, #005f33);
        }

        .btn-edit:hover {
            box-shadow: 0 3px 8px rgba(0,134,73,0.3);
        }

        .btn-expand {
            background: linear-gradient(135deg, #008649, #005f33);
        }

        .btn-expand:hover {
            box-shadow: 0 3px 8px rgba(0,134,73,0.3);
        }

        .detail-row {
            background: #f8fafb;
        }

        .detail-content {
            border-left: 3px solid #008649;
            margin: 0 12px;
        }

        .detail-table thead th {
            background: #f1f5f9;
            font-size: 11px;
            font-weight: 600;
            color: #64748b;
            padding: 6px 10px;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .detail-table tbody td {
            font-size: 12px;
            padding: 6px 10px;
        }

        .btn-search {
            background: linear-gradient(135deg, #008649, #005f33);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            padding: 8px 18px;
        }

        .btn-search:hover {
            background: linear-gradient(135deg, #006d3b, #004d29);
            color: white;
        }

        .btn-clear {
            background: #f1f5f9;
            border: 1.5px solid #e2e8f0;
            color: #64748b;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            padding: 8px 18px;
        }

        .btn-clear:hover {
            background: #e2e8f0;
        }

        .badge-count {
            background: #008649;
            color: white;
            font-size: 11px;
            padding: 2px 8px;
            border-radius: 20px;
            font-weight: 600;
        }

        .summary-bar {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
        }

        .summary-item {
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
            border-radius: 8px;
            padding: 8px 16px;
            font-size: 13px;
            font-weight: 600;
            color: #166534;
        }

        .summary-item .label {
            font-size: 11px;
            font-weight: 500;
            color: #64748b;
            text-transform: uppercase;
        }
    </style>
}

<div class="container-fluid px-0">
    <div id="alertContainer"></div>

    <div class="card main-card">
        <div class="card-body p-0">

            <!-- Top Bar -->
            <div class="top-bar d-flex justify-content-between align-items-center px-4 py-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="page-icon">
                        <i class="bi bi-receipt"></i>
                    </div>
                    <div>
                        <div class="page-title">Fee Vouchers</div>
                        <div class="page-subtitle">Payment Records</div>
                    </div>
                </div>
                <a href="/feevoucher/form" class="btn btn-add">
                    <i class="bi bi-plus-lg me-1"></i> Receive Payment
                </a>
            </div>

            <div class="px-4 pb-4">

                <!-- Filter Section -->
                <div class="section-card mb-3">
                    <div class="section-header">
                        <i class="bi bi-funnel me-2"></i>Filters
                    </div>
                    <div class="section-body">
                        <div class="row g-3">
                            <div class="col-lg-3 col-md-4 col-sm-6 col-12">
                                <label class="form-label">Date Range</label>
                                <input type="text" class="form-control" id="filterDateRange" placeholder="Select date range" readonly style="background: white; cursor: pointer;" />
                            </div>
                            <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                                <label class="form-label">Class</label>
                                <select class="form-select" id="filterClass" onchange="onFilterClassChange()">
                                    <option value="">All Classes</option>
                                </select>
                            </div>
                            <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                                <label class="form-label">Section</label>
                                <select class="form-select" id="filterSection" disabled onchange="onFilterSectionChange()">
                                    <option value="">All Sections</option>
                                </select>
                            </div>
                            <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                                <label class="form-label">Student</label>
                                <select class="form-select" id="filterStudent">
                                    <option value="">All Students</option>
                                </select>
                            </div>
                            <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                                <label class="form-label">Payment Method</label>
                                <select class="form-select" id="filterPaymentMethod">
                                    <option value="">All Methods</option>
                                </select>
                            </div>
                            <div class="col-lg-3 col-md-6 col-12">
                                <label class="form-label">Search</label>
                                <input type="text" class="form-control" id="searchText" placeholder="Voucher #, Student, Roll No..." />
                            </div>
                            <div class="col-lg-3 col-md-6 col-12 d-flex align-items-end gap-2">
                                <button type="button" class="btn btn-search" onclick="applyFilters()">
                                    <i class="bi bi-search me-1"></i> Search
                                </button>
                                <button type="button" class="btn btn-clear" onclick="clearFilters()">
                                    <i class="bi bi-x-lg me-1"></i> Clear
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Summary -->
                <div class="summary-bar mb-3" id="summaryBar" style="display: none;">
                    <div class="summary-item">
                        <div class="label">Total Records</div>
                        <div id="summaryCount">0</div>
                    </div>
                    <div class="summary-item">
                        <div class="label">Total Amount</div>
                        <div id="summaryAmount">0.00</div>
                    </div>
                </div>

                <!-- Voucher Grid -->
                <div class="section-card">
                    <div class="section-header">
                        <i class="bi bi-table me-2"></i>Payment Records
                        <span id="gridCount" class="badge-count ms-2"></span>
                    </div>
                    <div class="section-body p-0">
                        <div class="table-responsive">
                            <table class="table voucher-table mb-0">
                                <thead>
                                    <tr>
                                        <th style="width: 50px;">Sr#</th>
                                        <th>Voucher #</th>
                                        <th>Date</th>
                                        <th>Roll No</th>
                                        <th>Student</th>
                                        <th>Father Name</th>
                                        <th>Payment Method</th>
                                        <th class="text-end">Balance</th>
                                        <th class="text-end">Pending</th>
                                        <th class="text-end">Amount Paid</th>
                                        <th>Remarks</th>
                                        <th class="text-center" style="width: 120px;">Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="voucherBody">
                                    <tr>
                                        <td colspan="12" class="text-center text-muted py-4">
                                            <i class="bi bi-receipt me-2"></i>Loading payment records...
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        let allVouchers = [];
        let datePicker = null;

        $(document).ready(function () {
            const today = new Date();
            const firstDay = new Date(today.getFullYear(), today.getMonth(), 1);

            datePicker = flatpickr('#filterDateRange', {
                mode: 'range',
                dateFormat: 'Y-m-d',
                altInput: true,
                altFormat: 'd M Y',
                defaultDate: [firstDay, today]
            });

            loadDropdowns();
            loadVouchers();
        });

        // ── Load Dropdowns ──────────────────────────────────────
        async function loadDropdowns() {
            try {
                const [classes] = await Promise.all([
                    fetch(`${API_BASE}/class`).then(r => r.ok ? r.json() : [])
                ]);
                classes.forEach(c => $('#filterClass').append(`<option value="${c.vid}">${c.vName}</option>`));
            } catch (e) { console.error(e); }

            loadPaymentMethods();
        }

        async function loadPaymentMethods() {
            const staticMethods = [
                { id: 1, name: 'JazzCash' },
                { id: 2, name: 'EasyPaisa' },
                { id: 3, name: 'Cash' },
                { id: 4, name: 'Bank Transfer' }
            ];

            let methods = staticMethods;
            try {
                const r = await fetch(`${API_BASE}/PaymentMethod/dropdown`);
                if (r.ok) {
                    const data = await r.json();
                    if (data && data.length > 0) methods = data;
                }
            } catch { }

            const select = $('#filterPaymentMethod');
            methods.forEach(pm => {
                select.append(`<option value="${pm.id}">${pm.name}</option>`);
            });
        }

        // ── Class → Section → Student cascade ───────────────────
        async function onFilterClassChange() {
            const classId = $('#filterClass').val();
            const secSelect = $('#filterSection');
            const stuSelect = $('#filterStudent');

            secSelect.find('option:not(:first)').remove();
            stuSelect.find('option:not(:first)').remove();

            if (!classId) {
                secSelect.prop('disabled', true);
                return;
            }

            try {
                const r = await fetch(`${API_BASE}/section/byClass/${classId}`);
                if (r.ok) {
                    const sections = await r.json();
                    sections.forEach(s => secSelect.append(`<option value="${s.vid}">${s.vName}</option>`));
                    secSelect.prop('disabled', false);
                }
            } catch (e) { console.error(e); }

            await loadStudentFilter();
        }

        async function onFilterSectionChange() {
            await loadStudentFilter();
        }

        async function loadStudentFilter() {
            const classId   = $('#filterClass').val()   || 0;
            const sectionId = $('#filterSection').val() || 0;
            const stuSelect = $('#filterStudent');
            stuSelect.find('option:not(:first)').remove();

            if (!classId) return;

            try {
                const r = await fetch(`${API_BASE}/Student/students?classId=${classId}&sectionId=${sectionId}`);
                if (r.ok) {
                    const students = await r.json();
                    students.forEach(s => {
                        const roll = s.classRollNo || s.rollNo || '';
                        const label = `${s.name || '-'}${roll ? ' (' + roll + ')' : ''}`;
                        stuSelect.append(`<option value="${s.vid}">${label}</option>`);
                    });
                }
            } catch (e) { console.error(e); }
        }

        // ── Load Vouchers ───────────────────────────────────────
        async function loadVouchers() {
            $('#voucherBody').html('<tr><td colspan="12" class="text-center text-muted py-4"><span class="spinner-border spinner-border-sm me-2"></span>Loading...</td></tr>');

            try {
                const r = await fetch(`${API_BASE}/FeeVoucher`);
                if (r.ok) {
                    allVouchers = await r.json();
                    applyFilters();
                } else {
                    $('#voucherBody').html('<tr><td colspan="12" class="text-center text-muted py-4">Failed to load vouchers</td></tr>');
                }
            } catch (e) {
                console.error('Error loading vouchers:', e);
                $('#voucherBody').html('<tr><td colspan="12" class="text-center text-muted py-4">Error loading vouchers</td></tr>');
            }
        }

        // ── Apply Filters ───────────────────────────────────────
        function applyFilters() {
            let filtered = [...allVouchers];

            // Date range
            const dates = datePicker.selectedDates;
            if (dates.length > 0) {
                const fromDate = dates[0].toISOString().split('T')[0];
                filtered = filtered.filter(v => v.paymentDate && v.paymentDate.split('T')[0] >= fromDate);
            }
            if (dates.length > 1) {
                const toDate = dates[1].toISOString().split('T')[0];
                filtered = filtered.filter(v => v.paymentDate && v.paymentDate.split('T')[0] <= toDate);
            }

            // Class
            const classId = $('#filterClass').val();
            if (classId) {
                filtered = filtered.filter(v => v.classId == classId);
            }

            // Section
            const sectionId = $('#filterSection').val();
            if (sectionId) {
                filtered = filtered.filter(v => v.sectionId == sectionId);
            }

            // Student
            const studentId = $('#filterStudent').val();
            if (studentId) {
                filtered = filtered.filter(v => v.studentId == studentId);
            }

            // Payment Method
            const paymentMethodId = $('#filterPaymentMethod').val();
            if (paymentMethodId) {
                filtered = filtered.filter(v => v.paymentMethodId == paymentMethodId);
            }

            // Text search
            const searchText = $('#searchText').val().toLowerCase().trim();
            if (searchText) {
                filtered = filtered.filter(v =>
                    (v.voucherNumber && v.voucherNumber.toLowerCase().includes(searchText)) ||
                    (v.studentName && v.studentName.toLowerCase().includes(searchText)) ||
                    (v.rollNumber && v.rollNumber.toLowerCase().includes(searchText)) ||
                    (v.challanNumber && v.challanNumber.toLowerCase().includes(searchText)) ||
                    (v.transactionReference && v.transactionReference.toLowerCase().includes(searchText))
                );
            }

            renderList(filtered);
            updateSummary(filtered);
        }

        function renderList(items) {
            const tbody = $('#voucherBody');
            tbody.empty();

            $('#gridCount').text(items.length > 0 ? items.length : '');

            if (items.length === 0) {
                tbody.html('<tr><td colspan="12" class="text-center text-muted py-4"><i class="bi bi-inbox me-2"></i>No payment records found</td></tr>');
                return;
            }

            items.forEach((item, index) => {
                const row = `
                    <tr>
                        <td>${index + 1}</td>
                        <td><strong>${item.voucherNumber || '-'}</strong></td>
                        <td>${formatDate(item.paymentDate)}</td>
                        <td>${item.rollNumber || '-'}</td>
                        <td>${item.studentName || '-'}</td>
                        <td>${item.fatherName || '-'}</td>
                        <td>${item.paymentMethodName || '-'}</td>
                        <td class="text-end">${fmt(item.balance)}</td>
                        <td class="text-end text-danger">${fmt(item.pendingAmount)}</td>
                        <td class="text-end fw-bold text-success">${fmt(item.amountPaid)}</td>
                        <td>${item.remarks || '-'}</td>
                        <td class="text-center">
                            <button type="button" class="btn-action btn-edit me-1" onclick="editVoucher(${item.id})" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button type="button" class="btn-action btn-expand" onclick="toggleDetail(${item.id}, this)" title="Details">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </td>
                    </tr>
                    <tr id="detail_${item.id}" class="detail-row" style="display:none;">
                        <td colspan="12" class="p-0">
                            <div class="detail-content p-3">
                                <div class="text-center text-muted py-2"><span class="spinner-border spinner-border-sm me-2"></span>Loading fee details...</div>
                            </div>
                        </td>
                    </tr>
                `;
                tbody.append(row);
            });
        }

        function updateSummary(items) {
            const total = items.reduce((s, v) => s + (v.amountPaid || 0), 0);
            $('#summaryCount').text(items.length);
            $('#summaryAmount').text(fmt(total));
            $('#summaryBar').show();
        }

        function editVoucher(id) {
            window.location.href = `/feevoucher/form/${id}`;
        }

        async function toggleDetail(voucherId, btn) {
            const detailRow = $(`#detail_${voucherId}`);
            const icon = $(btn).find('i');

            if (detailRow.is(':visible')) {
                detailRow.hide();
                icon.removeClass('bi-dash-lg').addClass('bi-plus-lg');
                return;
            }

            icon.removeClass('bi-plus-lg').addClass('bi-dash-lg');
            detailRow.show();

            const content = detailRow.find('.detail-content');

            // Find the voucher to get studentId
            const voucher = allVouchers.find(v => v.id === voucherId);
            if (!voucher || !voucher.studentId) {
                content.html('<div class="text-muted py-2">No student linked to this voucher</div>');
                return;
            }

            try {
                const r = await fetch(`${API_BASE}/ApplyFee?studentId=${voucher.studentId}&dateFrom=2000-01-01&dateTo=2099-12-31`);
                if (!r.ok) { content.html('<div class="text-muted py-2">Failed to load fee details</div>'); return; }

                const fees = await r.json();
                if (fees.length === 0) {
                    content.html('<div class="text-muted py-2">No fee records found</div>');
                    return;
                }

                let html = `<table class="table table-sm mb-0 detail-table">
                    <thead><tr>
                        <th>Month</th><th>Fee Type</th><th>Class</th><th>Section</th><th>Grade</th>
                        <th class="text-end">Fee Amount</th><th class="text-end">Cleared</th>
                        <th class="text-end">Pending</th><th>Status</th>
                    </tr></thead><tbody>`;

                fees.forEach(f => {
                    const month = f.vDate ? new Date(f.vDate).toLocaleDateString('en-GB', { month: 'short', year: 'numeric' }) : '-';
                    const statusBadge = f.isClear
                        ? '<span class="badge bg-success">Cleared</span>'
                        : '<span class="badge bg-warning text-dark">Pending</span>';
                    html += `<tr>
                        <td>${month}</td>
                        <td>${f.feeTypeName || '-'}</td>
                        <td>${f.className || '-'}</td>
                        <td>${f.sectionName || '-'}</td>
                        <td>${f.gradeName || '-'}</td>
                        <td class="text-end">${fmt(f.feeAmount)}</td>
                        <td class="text-end text-success">${fmt(f.clearedAmount)}</td>
                        <td class="text-end text-danger">${fmt(f.pendingAmount)}</td>
                        <td>${statusBadge}</td>
                    </tr>`;
                });

                html += '</tbody></table>';
                content.html(html);
            } catch (e) {
                console.error(e);
                content.html('<div class="text-muted py-2">Error loading fee details</div>');
            }
        }

        function clearFilters() {
            const today = new Date();
            const firstDay = new Date(today.getFullYear(), today.getMonth(), 1);
            datePicker.setDate([firstDay, today]);
            $('#filterClass').val('');
            $('#filterSection').val('').prop('disabled', true).find('option:not(:first)').remove();
            $('#filterStudent').val('').find('option:not(:first)').remove();
            $('#filterPaymentMethod').val('');
            $('#searchText').val('');
            applyFilters();
        }

        function formatDate(dateString) {
            if (!dateString) return '-';
            const d = new Date(dateString);
            return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
        }

        function fmt(val) {
            return (val || 0).toLocaleString('en-PK', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }
    </script>
}
