@{
    ViewData["Title"] = "Receive Payment";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid px-0">
    <div id="alertContainer"></div>

    <div class="card main-card">
        <div class="card-body p-0">

            <!-- Top Bar -->
            <div class="top-bar d-flex justify-content-between align-items-center px-4 py-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="voucher-icon">
                        <i class="bi bi-receipt"></i>
                    </div>
                    <div>
                        <div class="page-title">Receive Payment</div>
                        <div class="voucher-no" id="voucherNoDisplay">New Voucher</div>
                    </div>
                </div>
                <a href="/feevoucher" class="btn btn-back">
                    <i class="bi bi-arrow-left me-1"></i> Back to List
                </a>
            </div>

            <div class="px-4 pb-4">

                <!-- ══════════════════════════════════════════════
                     SECTION 1 — FIND STUDENT
                ══════════════════════════════════════════════ -->
                <div class="section-card mb-3">
                    <div class="section-header">
                        <i class="bi bi-search me-2"></i>Find Student
                    </div>
                    <div class="section-body">
                        <div class="row g-3">
                            <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                                <label class="form-label">Class</label>
                                <select class="form-select" id="filterClass" onchange="onFilterClassChange()">
                                    <option value="">-- All Classes --</option>
                                </select>
                            </div>
                            <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                                <label class="form-label">Section</label>
                                <select class="form-select" id="filterSection" disabled>
                                    <option value="">-- All Sections --</option>
                                </select>
                            </div>
                            <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                                <label class="form-label">Student Name</label>
                                <input type="text" class="form-control" id="filterName" placeholder="Name..." />
                            </div>
                            <div class="col-lg-1 col-md-3 col-sm-6 col-12">
                                <label class="form-label">Roll No</label>
                                <input type="text" class="form-control" id="filterRollNo" placeholder="Roll#" />
                            </div>
                            <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                                <label class="form-label">Father Name</label>
                                <input type="text" class="form-control" id="filterFatherName" placeholder="Father Name..." />
                            </div>
                            <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                                <label class="form-label">Father CNIC</label>
                                <input type="text" class="form-control" id="filterFatherCNIC" placeholder="CNIC..." />
                            </div>
                            <div class="col-lg-1 col-md-3 col-sm-6 col-12 d-flex align-items-end">
                                <button type="button" class="btn btn-save w-100" onclick="searchStudents()">
                                    <i class="bi bi-search"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Search Results -->
                        <div id="searchResultsSection" class="mt-3" style="display: none;">
                            <div class="table-responsive" style="max-height: 250px; overflow-y: auto;">
                                <table class="table table-hover fee-table table-sm mb-0">
                                    <thead>
                                        <tr>
                                            <th style="width: 36px;"></th>
                                            <th>Name</th>
                                            <th>Roll No</th>
                                            <th>Class</th>
                                            <th>Section</th>
                                            <th>Father Name</th>
                                            <th>Father CNIC</th>
                                        </tr>
                                    </thead>
                                    <tbody id="searchResultsBody">
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Selected Student Info -->
                        <div class="col-12 mt-3" id="studentInfoRow" style="display:none;">
                            <div class="student-info-bar">
                                <span class="info-chip"><i class="bi bi-person me-1"></i><span id="infoStudentName">—</span></span>
                                <span class="info-chip"><i class="bi bi-people me-1"></i>Father: <span id="infoFatherName">—</span></span>
                                <span class="info-chip"><i class="bi bi-card-text me-1"></i>ID: <span id="infoStudentId">—</span></span>
                                <span class="info-chip balance-chip"><i class="bi bi-wallet2 me-1"></i>Balance: <span id="infoBalance">0.00</span></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ══════════════════════════════════════════════
                     SECTION 2 — FEE GRID (Pending Fees)
                ══════════════════════════════════════════════ -->
                <div class="section-card mb-3">
                    <div class="section-header">
                        <i class="bi bi-table me-2"></i>Pending Fees
                        <span id="feeGridCount" class="badge-count ms-2"></span>
                        <div class="ms-auto d-flex gap-2 align-items-center">
                            <button class="btn btn-xs btn-outline-primary" onclick="selectAllFees()">Select All</button>
                            <button class="btn btn-xs btn-outline-secondary" onclick="clearFeeSelection()">Clear</button>
                        </div>
                    </div>
                    <div class="section-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover fee-table mb-0">
                                <thead>
                                    <tr>
                                        <th style="width:40px;"><input type="checkbox" id="selectAllCheck" onchange="toggleAllFees(this)"></th>
                                        <th>Month</th>
                                        <th>Student</th>
                                        <th>Class</th>
                                        <th>Section</th>
                                        <th>Grade</th>
                                        <th>Fee Type</th>
                                        <th class="text-end">Fee Amount</th>
                                        <th class="text-end">Cleared</th>
                                        <th class="text-end">Pending</th>
                                        <th>Remarks</th>
                                    </tr>
                                </thead>
                                <tbody id="feeGridBody">
                                    <tr>
                                        <td colspan="11" class="text-center text-muted py-4">
                                            <i class="bi bi-person-x me-2"></i>Select a student to load fees
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- ══════════════════════════════════════════════
                     SECTION 3 — PAYMENT DETAILS
                ══════════════════════════════════════════════ -->
                <div class="section-card mb-3">
                    <div class="section-header">
                        <i class="bi bi-cash-stack me-2"></i>Payment Details
                    </div>
                    <div class="section-body">
                        <div class="row g-3">
                            <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                                <label class="form-label">Voucher No</label>
                                <input type="text" class="form-control" id="voucherNo" readonly placeholder="Auto generated" />
                            </div>
                            <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                                <label class="form-label">Date <span class="req">*</span></label>
                                <input type="date" class="form-control" id="paymentDate" />
                            </div>
                            <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                                <label class="form-label">Payment Method <span class="req">*</span></label>
                                <select class="form-select" id="paymentMethod">
                                    <option value="">-- Select --</option>
                                    <option value="1">JazzCash</option>
                                    <option value="2">EasyPaisa</option>
                                    <option value="3">Cash</option>
                                    <option value="4">Bank Transfer</option>
                                </select>
                            </div>
                            <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                                <label class="form-label">Father's Name</label>
                                <input type="text" class="form-control" id="fatherName" readonly placeholder="Auto filled" />
                            </div>
                            <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                                <label class="form-label">Balance</label>
                                <input type="text" class="form-control text-danger fw-bold" id="paymentBalance" readonly value="0.00" />
                            </div>
                            <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                                <label class="form-label">Amount <span class="req">*</span></label>
                                <input type="number" class="form-control fw-bold" id="totalAmount" readonly value="0.00" placeholder="0.00" />
                            </div>
                            <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                                <label class="form-label">Paid Amount <span class="req">*</span></label>
                                <input type="number" class="form-control text-success fw-bold" id="paidAmount"
                                       placeholder="0.00" oninput="calcRemaining()" />
                            </div>
                            <div class="col-lg-2 col-md-4 col-sm-6 col-12">
                                <label class="form-label">Remaining</label>
                                <input type="text" class="form-control text-warning fw-bold" id="remainingAmount" readonly value="0.00" />
                            </div>
                            <div class="col-lg-4 col-md-6 col-12">
                                <label class="form-label">Remarks</label>
                                <input type="text" class="form-control" id="remarks" placeholder="Optional note..." />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ══════════════════════════════════════════════
                     ACTION BAR
                ══════════════════════════════════════════════ -->
                <div class="action-bar d-flex justify-content-between align-items-center">
                    <div class="d-flex gap-2 align-items-center">
                        <label class="form-label mb-0 me-1" style="color:#475569;font-size:13px;">Printer:</label>
                        <div class="form-check form-check-inline mb-0">
                            <input class="form-check-input" type="radio" name="printerType" id="printerThermal" value="thermal" checked>
                            <label class="form-check-label" for="printerThermal">Thermal</label>
                        </div>
                        <div class="form-check form-check-inline mb-0">
                            <input class="form-check-input" type="radio" name="printerType" id="printerNormal" value="normal">
                            <label class="form-check-label" for="printerNormal">Normal</label>
                        </div>
                        <div class="form-check form-check-inline mb-0 ms-2">
                            <input class="form-check-input" type="checkbox" id="sendMessage">
                            <label class="form-check-label" for="sendMessage">Send Message</label>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <a href="/feevoucher" class="btn btn-cancel">
                            <i class="bi bi-x-lg me-1"></i> Close
                        </a>
                        <button type="button" class="btn btn-save" onclick="saveVoucher(false)">
                            <i class="bi bi-check-lg me-1"></i> Save
                        </button>
                        <button type="button" class="btn btn-save-print" onclick="saveVoucher(true)">
                            <i class="bi bi-printer me-1"></i> Save & Print
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .main-card {
            border: none;
            border-radius: 16px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.08);
            overflow: hidden;
        }

        /* ── Top Bar ── */
        .top-bar {
            background: linear-gradient(135deg, #008649 0%, #005f33 100%);
            color: white;
        }

        .voucher-icon {
            width: 44px;
            height: 44px;
            background: rgba(255,255,255,0.2);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .page-title {
            font-size: 16px;
            font-weight: 700;
            letter-spacing: 0.3px;
        }

        .voucher-no {
            font-size: 12px;
            opacity: 0.8;
            margin-top: 2px;
        }

        .btn-back {
            background: rgba(255,255,255,0.15);
            color: white;
            border: 1px solid rgba(255,255,255,0.3);
            border-radius: 8px;
            font-size: 13px;
            padding: 6px 14px;
        }

            .btn-back:hover {
                background: rgba(255,255,255,0.25);
                color: white;
            }

        /* ── Section Cards ── */
        .section-card {
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            overflow: hidden;
            margin-top: 16px;
        }

        .section-header {
            background: #f8fafc;
            padding: 10px 16px;
            font-size: 13px;
            font-weight: 600;
            color: #475569;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        .section-body {
            padding: 16px;
        }

        /* ── Student Info Bar ── */
        .student-info-bar {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            padding: 10px 14px;
            background: #f0fdf4;
            border-radius: 8px;
            border: 1px solid #bbf7d0;
        }

        .info-chip {
            font-size: 13px;
            color: #166534;
            background: white;
            padding: 4px 12px;
            border-radius: 20px;
            border: 1px solid #bbf7d0;
            font-weight: 500;
        }

        .balance-chip {
            background: #166534;
            color: white;
            border-color: #166534;
        }

        /* ── Fee Table ── */
        .fee-table thead th {
            background: #f8fafc;
            font-size: 12px;
            font-weight: 600;
            color: #64748b;
            padding: 10px 12px;
            border-bottom: 2px solid #e2e8f0;
            white-space: nowrap;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .fee-table tbody td {
            font-size: 13px;
            padding: 10px 12px;
            vertical-align: middle;
            border-bottom: 1px solid #f1f5f9;
        }

        .fee-table tbody tr:hover {
            background: #f8fafc;
        }

        .fee-table tbody tr.selected-row {
            background: #f0fdf4;
        }

        .badge-count {
            background: #008649;
            color: white;
            font-size: 11px;
            padding: 2px 8px;
            border-radius: 20px;
            font-weight: 600;
        }

        /* ── Form Controls ── */
        .form-label {
            font-size: 12px;
            font-weight: 600;
            color: #64748b;
            margin-bottom: 5px;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .req {
            color: #ef4444;
        }

        .form-control, .form-select {
            border: 1.5px solid #e2e8f0;
            border-radius: 8px;
            font-size: 13px;
            padding: 8px 12px;
            transition: all 0.2s;
        }

            .form-control:focus, .form-select:focus {
                border-color: #008649;
                box-shadow: 0 0 0 3px rgba(0,134,73,0.1);
            }

            .form-control[readonly] {
                background: #f8fafc;
                color: #64748b;
            }

        /* ── Action Bar ── */
        .action-bar {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 14px 20px;
            margin-top: 16px;
        }

        .btn-cancel {
            background: #f1f5f9;
            border: 1.5px solid #e2e8f0;
            color: #64748b;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            padding: 8px 18px;
        }

            .btn-cancel:hover {
                background: #e2e8f0;
            }

        .btn-save {
            background: linear-gradient(135deg, #008649, #005f33);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            padding: 8px 20px;
        }

            .btn-save:hover {
                background: linear-gradient(135deg, #006d3b, #004d29);
                color: white;
            }

        .btn-save-print {
            background: linear-gradient(135deg, #0ea5e9, #0284c7);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            padding: 8px 20px;
        }

            .btn-save-print:hover {
                opacity: 0.9;
                color: white;
            }

        .btn-xs {
            font-size: 11px;
            padding: 3px 10px;
            border-radius: 6px;
        }

        /* ── Misc ── */
        .text-success {
            color: #16a34a !important;
        }

        .text-danger {
            color: #dc2626 !important;
        }

        .text-warning {
            color: #d97706 !important;
        }
    </style>
}

@section Scripts {
    <script>
        let selectedStudentId = null;
        let selectedFees = [];   // checked fee VIDs

        $(document).ready(function () {
            setToday();
            loadDropdowns();
            loadVoucherNo();
        });

        // ── Today ─────────────────────────────────────────────────
        function setToday() {
            const today = new Date();
            const yyyy  = today.getFullYear();
            const mm    = String(today.getMonth() + 1).padStart(2, '0');
            const dd    = String(today.getDate()).padStart(2, '0');
            $('#paymentDate').val(`${yyyy}-${mm}-${dd}`);
        }

        // ── Voucher No ────────────────────────────────────────────
        async function loadVoucherNo() {
            try {
                const r = await fetch(`${API_BASE}/FeeVoucher/nextvoucherno`);
                if (r.ok) {
                    const data = await r.json();
                    const no = data.voucherNo || data;
                    $('#voucherNo').val(no);
                    $('#voucherNoDisplay').text(no);
                }
            } catch { }
        }

        // ── Dropdowns ─────────────────────────────────────────────
        async function loadDropdowns() {
            try {
                const r = await fetch(`${API_BASE}/class`);
                if (r.ok) {
                    const classes = await r.json();
                    classes.forEach(c => $('#filterClass').append(`<option value="${c.vid}">${c.vName}</option>`));
                }
            } catch (e) { console.error(e); }
        }

        // ── Class → Section cascade ──────────────────────────────
        async function onFilterClassChange() {
            const classId = $('#filterClass').val();
            const secSelect = $('#filterSection');
            secSelect.find('option:not(:first)').remove();

            if (!classId) {
                secSelect.prop('disabled', true);
                return;
            }

            try {
                const r = await fetch(`${API_BASE}/section/byClass/${classId}`);
                if (r.ok) {
                    const sections = await r.json();
                    sections.forEach(s => secSelect.append(`<option value="${s.vid}">${s.vName}</option>`));
                    secSelect.prop('disabled', false);
                }
            } catch (e) { console.error(e); }
        }

        // ── Search Students ──────────────────────────────────────
        async function searchStudents() {
            const params = new URLSearchParams();
            const classId    = $('#filterClass').val();
            const sectionId  = $('#filterSection').val();
            const name       = $('#filterName').val().trim();
            const rollNo     = $('#filterRollNo').val().trim();
            const fatherName = $('#filterFatherName').val().trim();
            const fatherCNIC = $('#filterFatherCNIC').val().trim();

            if (classId)    params.append('classId', classId);
            if (sectionId)  params.append('sectionId', sectionId);
            if (name)       params.append('name', name);
            if (rollNo)     params.append('rollNo', rollNo);
            if (fatherName) params.append('fatherName', fatherName);
            if (fatherCNIC) params.append('fatherCNIC', fatherCNIC);

            if (!params.toString()) {
                toastWarning('Please enter at least one filter');
                return;
            }

            const tbody = $('#searchResultsBody');
            tbody.html('<tr><td colspan="7" class="text-center text-muted py-3"><span class="spinner-border spinner-border-sm me-2"></span>Searching...</td></tr>');
            $('#searchResultsSection').show();

            try {
                const r = await fetch(`${API_BASE}/student/search?${params}`);
                if (!r.ok) { tbody.html('<tr><td colspan="7" class="text-center text-muted py-3">Search failed</td></tr>'); return; }

                const students = await r.json();
                if (students.length === 0) {
                    tbody.html('<tr><td colspan="7" class="text-center text-muted py-3">No students found</td></tr>');
                    return;
                }

                let rows = '';
                students.forEach(s => {
                    rows += `
                        <tr style="cursor:pointer;" onclick="selectStudent(${s.vid}, '${(s.name || '').replace(/'/g, "\\'")}', '${(s.fatherName || '').replace(/'/g, "\\'")}', '${s.rollNo || s.classRollNo || ''}', '${(s.fatherCNIC || '').replace(/'/g, "\\'")}')">
                            <td class="text-center text-success"><i class="bi bi-arrow-right-circle"></i></td>
                            <td>${s.name || '-'}</td>
                            <td>${s.rollNo || s.classRollNo || '-'}</td>
                            <td>${s.className || '-'}</td>
                            <td>${s.sectionName || '-'}</td>
                            <td>${s.fatherName || '-'}</td>
                            <td>${s.fatherCNIC || '-'}</td>
                        </tr>`;
                });
                tbody.html(rows);
            } catch (e) {
                console.error(e);
                tbody.html('<tr><td colspan="7" class="text-center text-muted py-3">Error searching students</td></tr>');
            }
        }

        // ── Select Student from search results ───────────────────
        async function selectStudent(id, name, father, rollNo, fatherCNIC) {
            selectedStudentId = id;
            $('#searchResultsSection').hide();

            $('#infoStudentName').text(name || '—');
            $('#infoFatherName').text(father || '—');
            $('#infoStudentId').text(id);
            $('#fatherName').val(father || '');
            $('#studentInfoRow').show();

            await loadPendingFees(id);
        }

        // ── Load Pending Fees ─────────────────────────────────────
        async function loadPendingFees(studentId) {
            $('#feeGridBody').html('<tr><td colspan="11" class="text-center text-muted py-3"><span class="spinner-border spinner-border-sm me-2"></span>Loading fees...</td></tr>');
            selectedFees = [];
            updateTotals();

            try {
                const r = await fetch(`${API_BASE}/ApplyFee?studentId=${studentId}&dateFrom=2000-01-01&dateTo=2099-12-31`);
                if (!r.ok) { resetFeeGrid('Failed to load fees'); return; }

                const fees = await r.json();
                const pending = fees.filter(f => !f.isClear);

                if (pending.length === 0) {
                    $('#feeGridBody').html('<tr><td colspan="11" class="text-center text-muted py-4"><i class="bi bi-check-circle text-success me-2"></i>No pending fees</td></tr>');
                    $('#feeGridCount').text('');
                    return;
                }

                $('#feeGridCount').text(pending.length);

                let rows = '';
                pending.forEach(f => {
                    const month = new Date(f.vDate).toLocaleDateString('en-GB', { month: 'short', year: 'numeric' });
                    rows += `
                        <tr id="feeRow_${f.vid}" data-vid="${f.vid}" data-pending="${f.pendingAmount || 0}">
                            <td><input type="checkbox" class="fee-check" value="${f.vid}"
                                       data-amount="${f.pendingAmount || 0}"
                                       onchange="onFeeChecked(this)"></td>
                            <td>${month}</td>
                            <td>${f.studentName || '-'}</td>
                            <td>${f.className   || '-'}</td>
                            <td>${f.sectionName || '-'}</td>
                            <td>${f.gradeName   || '-'}</td>
                            <td>${f.feeTypeName || '-'}</td>
                            <td class="text-end">${fmt(f.feeAmount)}</td>
                            <td class="text-end text-success">${fmt(f.clearedAmount)}</td>
                            <td class="text-end text-danger fw-bold">${fmt(f.pendingAmount)}</td>
                            <td>${f.remarks || '-'}</td>
                        </tr>`;
                });
                $('#feeGridBody').html(rows);

                // Balance = total pending
                const totalPending = pending.reduce((s, f) => s + (f.pendingAmount || 0), 0);
                $('#infoBalance').text(fmt(totalPending));
                $('#paymentBalance').val(fmt(totalPending));

            } catch (e) {
                console.error(e);
                resetFeeGrid('Error loading fees');
            }
        }

        // ── Fee Checkbox Logic ────────────────────────────────────
        function onFeeChecked(chk) {
            const row = $(chk).closest('tr');
            if (chk.checked) {
                row.addClass('selected-row');
                selectedFees.push({ vid: chk.value, amount: parseFloat(chk.dataset.amount) || 0 });
            } else {
                row.removeClass('selected-row');
                selectedFees = selectedFees.filter(f => f.vid !== chk.value);
            }
            updateTotals();
        }

        function toggleAllFees(masterChk) {
            $('.fee-check').each(function () {
                this.checked = masterChk.checked;
                onFeeChecked(this);
            });
        }

        function selectAllFees()    { $('#selectAllCheck').prop('checked', true).trigger('change'); }
        function clearFeeSelection(){ $('#selectAllCheck').prop('checked', false).trigger('change'); }

        // ── Update Totals ─────────────────────────────────────────
        function updateTotals() {
            const total = selectedFees.reduce((s, f) => s + f.amount, 0);
            $('#totalAmount').val(total.toFixed(2));
            calcRemaining();
        }

        function calcRemaining() {
            const total   = parseFloat($('#totalAmount').val())  || 0;
            const paid    = parseFloat($('#paidAmount').val())   || 0;
            const remaining = total - paid;
            $('#remainingAmount').val(remaining.toFixed(2));
            $('#remainingAmount').toggleClass('text-danger', remaining > 0)
                                 .toggleClass('text-success', remaining <= 0);
        }

        // ── Save ──────────────────────────────────────────────────
        async function saveVoucher(printAfter) {
            const paymentDate  = $('#paymentDate').val();
            const paymentMethod= $('#paymentMethod').val();
            const paidAmount   = parseFloat($('#paidAmount').val()) || 0;

            if (!selectedStudentId) { toastWarning('Please select a student'); return; }
            if (!paymentDate)   { toastWarning('Please select date'); return; }
            if (!paymentMethod) { toastWarning('Please select payment method'); return; }
            if (selectedFees.length === 0) { toastWarning('Please select at least one fee'); return; }
            if (paidAmount <= 0){ toastWarning('Please enter paid amount'); return; }

            const payload = {
                studentId:       parseInt(selectedStudentId),
                paymentDate:     paymentDate,
                paymentMethodId: parseInt(paymentMethod),
                paidAmount:      paidAmount,
                remarks:         $('#remarks').val(),
                sendMessage:     $('#sendMessage').is(':checked'),
                feeVids:         selectedFees.map(f => parseInt(f.vid))
            };

            try {
                $('[onclick*="saveVoucher"]').prop('disabled', true);
                const r = await fetch(`${API_BASE}/FeeVoucher`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const result = await r.json();

                if (r.ok) {
                    toastSuccess('Voucher saved successfully!');
                    if (printAfter) {
                        const printer = $('input[name="printerType"]:checked').val();
                        window.open(`/feevoucher/print/${result.id}?printer=${printer}`, '_blank');
                    }
                    setTimeout(() => window.location.href = '/feevoucher', 1200);
                } else {
                    toastError(result.message || 'Failed to save voucher');
                }
            } catch (e) {
                console.error(e);
                toastError('Error saving voucher');
            } finally {
                $('[onclick*="saveVoucher"]').prop('disabled', false);
            }
        }

        // ── Helpers ───────────────────────────────────────────────
        function resetFeeGrid(msg) {
            const text = msg || 'Select a student to load fees';
            $('#feeGridBody').html(`<tr><td colspan="11" class="text-center text-muted py-4"><i class="bi bi-person-x me-2"></i>${text}</td></tr>`);
            $('#feeGridCount').text('');
            selectedFees = [];
            updateTotals();
        }

        function fmt(val) {
            return (val || 0).toLocaleString('en-PK', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }
    </script>
}
