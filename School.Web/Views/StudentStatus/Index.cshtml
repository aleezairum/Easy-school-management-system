@{
    ViewData["Title"] = "Student Status Management";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    .card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
        margin-bottom: 24px;
    }

    .card-header {
        background: white;
        border-bottom: 1px solid #e2e8f0;
        padding: 20px 24px;
        border-radius: 16px 16px 0 0 !important;
    }

    .card-header h5 {
        margin: 0;
        font-weight: 600;
        color: #1e293b;
    }

    .card-body {
        padding: 24px;
    }

    .form-label {
        font-weight: 500;
        color: #475569;
        margin-bottom: 8px;
        font-size: 14px;
    }

    .form-control, .form-select {
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 14px;
        transition: all 0.2s;
    }

    .form-control:focus, .form-select:focus {
        border-color: #008649;
        box-shadow: 0 0 0 4px rgba(0, 134, 73, 0.1);
    }

    .form-check-input {
        width: 18px;
        height: 18px;
        border: 2px solid #cbd5e1;
        border-radius: 4px;
        cursor: pointer;
    }

    .form-check-input:checked {
        background-color: #008649;
        border-color: #008649;
    }

    .form-check-input:focus {
        box-shadow: 0 0 0 4px rgba(0, 134, 73, 0.1);
    }

    .btn-primary {
        background: linear-gradient(135deg, #008649 0%, #006d3b 100%);
        border: none;
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 600;
        font-size: 14px;
        transition: all 0.2s;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(0, 134, 73, 0.4);
        background: linear-gradient(135deg, #006d3b 0%, #005a30 100%);
    }

    .btn-secondary {
        background: #f1f5f9;
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 600;
        font-size: 14px;
        color: #64748b;
        transition: all 0.2s;
    }

    .btn-secondary:hover {
        background: #e2e8f0;
        border-color: #cbd5e1;
        color: #475569;
    }

    .btn-info {
        background: linear-gradient(135deg, #008649 0%, #006d3b 100%);
        border: none;
        border-radius: 8px;
        padding: 6px 12px;
        font-weight: 600;
        font-size: 13px;
        color: white;
        transition: all 0.2s;
    }

    .btn-info:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(0, 134, 73, 0.4);
        color: white;
    }

    .btn-danger {
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        border: none;
        border-radius: 8px;
        padding: 6px 12px;
        font-weight: 600;
        font-size: 13px;
        color: white;
        transition: all 0.2s;
    }

    .btn-danger:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.4);
        color: white;
    }

    .table {
        margin-bottom: 0;
    }

    .table thead th {
        background: #f8fafc;
        border-bottom: 2px solid #e2e8f0;
        padding: 14px 16px;
        font-weight: 600;
        font-size: 13px;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        white-space: nowrap;
    }

    .table tbody td {
        padding: 12px 16px;
        vertical-align: middle;
        border-bottom: 1px solid #f1f5f9;
        font-size: 14px;
    }

    .table tbody tr:hover {
        background: #f8fafc;
    }

    .table tbody tr.selected {
        background: #ecfdf5;
        border-left: 3px solid #008649;
    }

    .alert {
        border-radius: 12px;
        border: none;
        padding: 16px 20px;
    }

    .alert-success {
        background: #dcfce7;
        color: #166534;
    }

    .alert-danger {
        background: #fee2e2;
        color: #991b1b;
    }

    .loading-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255, 255, 255, 0.8);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 100;
        border-radius: 16px;
    }

    .spinner-border {
        width: 3rem;
        height: 3rem;
        border-width: 0.3rem;
    }

    .form-section {
        background: #f8fafc;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 20px;
    }

    .form-section-title {
        font-size: 14px;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 16px;
        padding-bottom: 8px;
        border-bottom: 2px solid #e2e8f0;
    }

    .grid-section {
        margin-top: 24px;
    }

    .grid-section-title {
        font-size: 14px;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 16px;
        padding-bottom: 8px;
        border-bottom: 2px solid #e2e8f0;
    }
</style>

<div class="container-fluid">
    <!-- Alert Messages -->
    <div id="alertContainer"></div>

    <!-- Student Status Card -->
    <div class="card">
        <div class="card-body position-relative">
            <div id="loadingOverlay" class="loading-overlay" style="display: none;">
                <div class="spinner-border text-success" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>

            <!-- Form Section -->
            <div class="form-section">
                <div class="form-section-title">
                    <i class="bi bi-pencil-square me-2"></i><span id="formTitle">Add New Student Status</span>
                </div>
                <form id="statusForm">
                    <input type="hidden" id="statusId" value="0" />

                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            <label for="statusName" class="form-label">Status Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="statusName" placeholder="e.g., Active, Left, Struck Off" required />
                        </div>
                        <div class="col-md-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="isActive" checked />
                                <label class="form-check-label" for="isActive">Active</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-primary" onclick="saveStatus()">
                                    <i class="bi bi-check-lg me-1"></i> Save
                                </button>
                                <button type="button" class="btn btn-secondary" onclick="resetForm()">
                                    <i class="bi bi-x-lg me-1"></i> Clear
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Grid Section -->
            <div class="grid-section">
                <div class="grid-section-title">
                    <i class="bi bi-table me-2"></i>Student Status List
                </div>
                <div class="table-responsive">
                    <table class="table table-hover" id="statusTable">
                        <thead>
                            <tr>
                                <th style="width: 60px;">Sr#</th>
                                <th>Status Name</th>
                                <th class="text-center" style="width: 100px;">Status</th>
                                <th class="text-center" style="width: 120px; white-space: nowrap;">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="statusBody">
                            <!-- Statuses will be loaded dynamically -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let editingStatusId = 0;

        $(document).ready(function () {
            loadStatuses();
        });

        // Load all statuses
        async function loadStatuses() {
            showLoading();
            try {
                const response = await fetch(`${API_BASE}/studentstatus`);
                if (response.ok) {
                    const statuses = await response.json();
                    renderStatusList(statuses);
                } else {
                    showAlert('Failed to load student statuses', 'danger');
                }
            } catch (error) {
                console.error('Error loading statuses:', error);
                showAlert('Error loading statuses: ' + error.message, 'danger');
            } finally {
                hideLoading();
            }
        }

        // Render status list table
        function renderStatusList(statuses) {
            const tbody = $('#statusBody');
            tbody.empty();

            if (statuses.length === 0) {
                tbody.html('<tr><td colspan="4" class="text-center text-muted py-4">No student statuses found. Add a new status using the form above.</td></tr>');
                return;
            }

            statuses.forEach((item, index) => {
                const row = `
                    <tr data-id="${item.viD}" class="${editingStatusId === item.viD ? 'selected' : ''}">
                        <td>${index + 1}</td>
                        <td><strong>${item.vName}</strong></td>
                        <td class="text-center">
                            <span class="badge ${item.isActive ? 'bg-success' : 'bg-secondary'}">
                                ${item.isActive ? 'Active' : 'Inactive'}
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-1 flex-nowrap">
                                <button type="button" class="btn btn-sm btn-info" onclick="editStatus(${item.vid})" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button type="button" class="btn btn-sm btn-danger" onclick="deleteStatus(${item.vid}, '${item.vName}')" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
                tbody.append(row);
            });
        }

        // Edit existing status
        async function editStatus(statusId) {
            showLoading();
            try {
                const response = await fetch(`${API_BASE}/studentstatus/${statusId}`);
                if (response.ok) {
                    const data = await response.json();
                    populateForm(data);
                    editingStatusId = statusId;
                    $('#formTitle').text('Edit Student Status');

                    $('#statusBody tr').removeClass('selected');
                    $(`#statusBody tr[data-id="${statusId}"]`).addClass('selected');

                    $('html, body').animate({
                        scrollTop: $('.form-section').offset().top - 100
                    }, 300);
                } else {
                    showAlert('Failed to load student status', 'danger');
                }
            } catch (error) {
                console.error('Error loading status:', error);
                showAlert('Error loading status: ' + error.message, 'danger');
            } finally {
                hideLoading();
            }
        }

        // Delete status
        async function deleteStatus(statusId, statusName) {
            if (!confirm(`Are you sure you want to delete the status "${statusName}"?`)) {
                return;
            }

            showLoading();
            try {
                const response = await fetch(`${API_BASE}/studentstatus/${statusId}`, {
                    method: 'DELETE'
                });

                if (response.ok) {
                    showAlert('Student status deleted successfully!', 'success');
                    if (editingStatusId === statusId) {
                        resetForm();
                    }
                    await loadStatuses();
                } else {
                    const error = await response.json();
                    showAlert(error.message || 'Failed to delete status', 'danger');
                }
            } catch (error) {
                console.error('Error deleting status:', error);
                showAlert('Error deleting status: ' + error.message, 'danger');
            } finally {
                hideLoading();
            }
        }

        // Populate form with status data
        function populateForm(data) {
            $('#statusId').val(data.vid);
            $('#statusName').val(data.vName);
            $('#isActive').prop('checked', data.isActive);
        }

        // Reset form
        function resetForm() {
            $('#statusId').val('0');
            $('#statusName').val('');
            $('#isActive').prop('checked', true);
            $('#formTitle').text('Add New Student Status');
            editingStatusId = 0;

            $('#statusBody tr').removeClass('selected');
        }

        // Save status
        async function saveStatus() {
            const statusName = $('#statusName').val().trim();

            if (!statusName) {
                showAlert('Please enter a status name', 'danger');
                $('#statusName').focus();
                return;
            }

            const statusId = parseInt($('#statusId').val()) || 0;
            const data = {
                VID: statusId,
                VName: statusName,
                IsActive: $('#isActive').is(':checked')
            };

            showLoading();
            try {
                const response = await fetch(`${API_BASE}/studentstatus`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                if (response.ok) {
                    showAlert(statusId === 0 ? 'Student status created successfully!' : 'Student status updated successfully!', 'success');
                    resetForm();
                    await loadStatuses();
                } else {
                    const error = await response.json();
                    showAlert(error.message || 'Failed to save status', 'danger');
                }
            } catch (error) {
                console.error('Error saving status:', error);
                showAlert('Error saving status: ' + error.message, 'danger');
            } finally {
                hideLoading();
            }
        }

        // Helper functions
        function showLoading() {
            $('#loadingOverlay').show();
        }

        function hideLoading() {
            $('#loadingOverlay').hide();
        }

        function showAlert(message, type) {
            if (type === 'success') {
                toastSuccess(message);
            } else if (type === 'danger' || type === 'error') {
                toastError(message);
            } else if (type === 'warning') {
                toastWarning(message);
            } else {
                toastInfo(message);
            }
        }
    </script>
}
